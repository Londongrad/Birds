{
  "Database": {
    "Provider": "Sqlite",
    "RemoteSync": {
      "Enabled": true,
      "ConnectionStringName": "Postgres"
    }
  },
  "Seeding": {
    "Mode": "None",
    "RecordCount": 20000,
    "BatchSize": 500,
    "RandomSeed": 42
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=${LOCALAPPDATA}\\Birds\\birds.db",
    "Postgres": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Birds": "Debug"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadId"
    ]
  }
}
