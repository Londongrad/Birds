<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization">

    <Style
        x:Key="ActionButtonBase"
        TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="9">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{DynamicResource ThemeNotificationCardHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush"
                                    Value="{DynamicResource ThemeNotificationUnreadBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="PrimaryActionButtonBase"
        BasedOn="{StaticResource ActionButtonBase}"
        TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentButtonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentButtonBorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="9">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{DynamicResource ThemeAccentButtonHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush"
                                    Value="{DynamicResource ThemeAccentButtonBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="DangerActionButtonBase"
        BasedOn="{StaticResource ActionButtonBase}"
        TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ThemeDangerButtonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeDangerButtonBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeDangerButtonForegroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="9">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{DynamicResource ThemeDangerButtonHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush"
                                    Value="{DynamicResource ThemeDangerButtonBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="EditButtonStyle"
        BasedOn="{StaticResource ActionButtonBase}"
        TargetType="Button">
        <Setter Property="Content" Value="&#xE70F;" />
    </Style>

    <Style
        x:Key="DeleteButtonStyle"
        BasedOn="{StaticResource DangerActionButtonBase}"
        TargetType="Button">
        <Setter Property="Content" Value="&#xE74D;" />
    </Style>

    <Style
        x:Key="ConfirmButtonStyle"
        BasedOn="{StaticResource PrimaryActionButtonBase}"
        TargetType="Button">
        <Setter Property="Content" Value="&#xE73E;" />
    </Style>

    <Style
        x:Key="CancelButtonStyle"
        BasedOn="{StaticResource ActionButtonBase}"
        TargetType="Button">
        <Setter Property="Content" Value="&#xE711;" />
    </Style>

    <Style
        x:Key="SaveButtonStyle"
        BasedOn="{StaticResource PrimaryActionButtonBase}"
        TargetType="Button">
        <Setter Property="Content" Value="&#xE74E;" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSaveLockedByDepartureRequirement}" Value="True">
                <Setter Property="Content" Value="&#xE72E;" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="CancelEditButtonStyle"
        BasedOn="{StaticResource ActionButtonBase}"
        TargetType="Button">
        <Setter Property="Content" Value="&#xE711;" />
    </Style>

    <DataTemplate x:Key="NormalButtonsTemplate">
        <StackPanel
            Orientation="Horizontal"
            VerticalAlignment="Center">
            <Button
                Command="{Binding EditCommand}"
                Margin="0,0,6,0"
                Style="{StaticResource EditButtonStyle}"
                ToolTip="{loc:Loc Key=Bird.Action.Edit}" />
            <Button
                Command="{Binding AskDeleteCommand}"
                Style="{StaticResource DeleteButtonStyle}"
                ToolTip="{loc:Loc Key=Bird.Action.Delete}" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="ConfirmButtonsTemplate">
        <StackPanel
            Orientation="Horizontal"
            VerticalAlignment="Center">
            <Button
                Command="{Binding DeleteCommand}"
                Margin="0,0,6,0"
                Style="{StaticResource ConfirmButtonStyle}"
                ToolTip="{loc:Loc Key=Bird.Action.ConfirmDelete}" />
            <Button
                Command="{Binding CancelDeleteCommand}"
                Style="{StaticResource CancelButtonStyle}"
                ToolTip="{loc:Loc Key=Bird.Action.CancelDelete}" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditButtonsTemplate">
        <StackPanel
            Orientation="Horizontal"
            VerticalAlignment="Center">
            <Button
                Command="{Binding SaveCommand}"
                Margin="0,0,6,0"
                Style="{StaticResource SaveButtonStyle}"
                ToolTipService.ShowOnDisabled="True"
                ToolTip="{loc:Loc Key=Bird.Action.Save}" />
            <Button
                Command="{Binding CancelEditCommand}"
                Style="{StaticResource CancelEditButtonStyle}"
                ToolTip="{loc:Loc Key=Bird.Action.CancelEdit}" />
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>