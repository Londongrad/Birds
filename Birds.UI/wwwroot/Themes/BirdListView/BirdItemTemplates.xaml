<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Birds.UI.Views.Helpers"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization">

    <DataTemplate x:Key="BirdNameComboTemplate">
        <TextBlock
            FontSize="16"
            Foreground="{DynamicResource ThemePrimaryTextBrush}"
            TextTrimming="CharacterEllipsis"
            Text="{Binding Converter={StaticResource BirdNameDisplayConverter}}" />
    </DataTemplate>

    <Style
        x:Key="BirdCardComboBoxItemStyle"
        TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="ItemBorder"
                        Margin="4,2"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentButtonBorderBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate
        x:Key="BirdCardComboBoxToggleTemplate"
        TargetType="ToggleButton">
        <Border
            x:Name="ToggleBorder"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="10">
            <Path
                Width="10"
                Height="6"
                Margin="0,0,14,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Data="M 0 0 L 5 5 L 10 0"
                Stroke="{DynamicResource ThemeMutedTextBrush}"
                StrokeThickness="1.6"
                StrokeEndLineCap="Round"
                StrokeStartLineCap="Round" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate
        x:Key="BirdCardComboBoxTemplate"
        TargetType="ComboBox">
        <Grid x:Name="ComboRoot">
            <ToggleButton
                x:Name="ToggleButton"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="1"
                ClickMode="Press"
                Focusable="False"
                IsChecked="{Binding IsDropDownOpen,
                                    Mode=TwoWay,
                                    RelativeSource={RelativeSource TemplatedParent}}"
                Template="{StaticResource BirdCardComboBoxToggleTemplate}" />

            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                Content="{TemplateBinding SelectionBoxItem}"
                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                IsHitTestVisible="False" />

            <Popup
                x:Name="PART_Popup"
                AllowsTransparency="True"
                IsOpen="{TemplateBinding IsDropDownOpen}"
                Placement="Bottom"
                PopupAnimation="Fade"
                StaysOpen="False">
                <Border
                    Width="{Binding ActualWidth, ElementName=ComboRoot}"
                    Margin="0,4,0,0"
                    Padding="0,6,6,6"
                    Background="{DynamicResource ThemeInsetBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <ScrollViewer
                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                        CanContentScroll="False"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="HasItems" Value="False">
                <Setter TargetName="PART_Popup" Property="MinHeight" Value="0" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style
        x:Key="BirdCardTitleTextStyle"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style
        x:Key="BirdCardDescriptionTextStyle"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style
        x:Key="BirdCardMetaLabelStyle"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
    </Style>

    <Style
        x:Key="BirdCardMetaValueStyle"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
    </Style>

    <Style
        x:Key="BirdCardMetaChipStyle"
        TargetType="Border">
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Background" Value="{DynamicResource ThemeInsetBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style
        x:Key="BirdCardMetaSeparatorStyle"
        TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="14,4" />
        <Setter Property="Background" Value="{DynamicResource ThemeCardBorderBrush}" />
        <Setter Property="Opacity" Value="0.75" />
    </Style>

    <Style
        x:Key="BirdCardFieldLabelStyle"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
    </Style>

    <Style
        x:Key="BirdCardInlineErrorStyle"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="12,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeFieldBorderErrorBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Visibility" Value="Collapsed" />
    </Style>

    <Style
        x:Key="BirdCardRoundIconButtonStyle"
        TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeNotificationActionBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="999">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ThemeNotificationCardHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ThemeNotificationCardHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="BirdCardComboBoxStyle"
        TargetType="ComboBox">
        <Setter Property="Validation.ErrorTemplate" Value="{DynamicResource FieldErrorTemplate_Universal}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="12,0,34,0" />
        <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource BirdCardComboBoxItemStyle}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="MaxDropDownHeight" Value="156" />
        <Setter Property="Template" Value="{StaticResource BirdCardComboBoxTemplate}" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderErrorBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="BirdCardTextBoxStyle"
        BasedOn="{StaticResource TextBoxAdd}"
        TargetType="TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="MaxHeight" Value="72" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style
        x:Key="BirdCardDatePickerStyle"
        BasedOn="{StaticResource DatePickerAdd}"
        TargetType="DatePicker">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style
        x:Key="BirdCardInlineToggleStyle"
        TargetType="CheckBox">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            x:Name="Track"
                            Width="40"
                            Height="22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{DynamicResource ThemeToggleTrackOffBrush}"
                            BorderBrush="{DynamicResource ThemeToggleBorderOffBrush}"
                            BorderThickness="1"
                            CornerRadius="11" />

                        <Ellipse
                            x:Name="Thumb"
                            Width="16"
                            Height="16"
                            Margin="3,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource ThemePrimaryTextBrush}"
                            StrokeThickness="0" />

                        <ContentPresenter
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            RecognizesAccessKey="True" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeToggleTrackOnBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeToggleBorderOnBrush}" />
                            <Setter TargetName="Thumb" Property="Margin" Value="21,0,0,0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="BirdViewTemplate">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Style="{StaticResource BirdCardTitleTextStyle}"
                    Text="{Binding DisplayName}" />

                <Border
                    Grid.Column="1"
                    Padding="10,5"
                    VerticalAlignment="Center"
                    CornerRadius="999">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ThemeStatusAliveBackgroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
                                    <Setter Property="Background" Value="{DynamicResource ThemeStatusDeadBackgroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                        Text="{Binding StatusText}" />
                </Border>
            </Grid>

            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                ToolTip="{Binding Description}">
                <TextBlock.Style>
                    <Style BasedOn="{StaticResource BirdCardDescriptionTextStyle}" TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding Description}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Description}" Value="">
                                <Setter Property="Text" Value="{loc:Loc Key=Bird.NoDescription}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                <Setter Property="Text" Value="{loc:Loc Key=Bird.NoDescription}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border
                Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14,10"
                Background="{DynamicResource ThemeInsetBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.ArrivalMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding ArrivalDisplay}" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.DepartureMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding DepartureDisplay}" />
                        </StackPanel>

                        <Border
                            Grid.Column="3"
                            Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                        <StackPanel
                            Grid.Column="4"
                            MinWidth="112">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.DurationMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding DurationDisplay}" />
                        </StackPanel>
                    </Grid>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <Grid Grid.Column="2">
                        <ContentPresenter
                            x:Name="NormalButtons"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource NormalButtonsTemplate}">
                            <ContentPresenter.Visibility>
                                <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                    <Binding Path="IsConfirmingDelete" />
                                    <Binding Path="IsEditing" />
                                </MultiBinding>
                            </ContentPresenter.Visibility>
                        </ContentPresenter>

                        <ContentPresenter
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ConfirmButtonsTemplate}"
                            Visibility="{Binding IsConfirmingDelete,
                                                 Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="BirdEditTemplate">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Column="0"
                    Margin="0,0,16,0"
                    VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=AddBird.SpeciesLabel}" />
                        <TextBlock
                            Grid.Column="1"
                            MaxWidth="180"
                            Text="{Binding ElementName=SpeciesField, Path=(Validation.Errors)[0].ErrorContent}">
                            <TextBlock.Style>
                                <Style
                                    BasedOn="{StaticResource BirdCardInlineErrorStyle}"
                                    TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=SpeciesField, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox
                        x:Name="SpeciesField"
                        Grid.Row="1"
                        IsEditable="False"
                        ItemTemplate="{StaticResource BirdNameComboTemplate}"
                        ItemsSource="{Binding BirdNames}"
                        SelectedItem="{Binding SelectedBirdName,
                                               Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged,
                                               ValidatesOnNotifyDataErrors=True}"
                        Style="{StaticResource BirdCardComboBoxStyle}"
                        Validation.ErrorTemplate="{StaticResource NoErrorTemplate}"
                        Width="280" />
                </Grid>

                <Border
                    Grid.Column="2"
                    Width="144"
                    Padding="12,8"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource ThemeInsetBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.StatusLabel}" />
                        <CheckBox
                            Content="{Binding StatusText}"
                            IsChecked="{Binding IsAlive,
                                                Mode=TwoWay}"
                            Style="{StaticResource BirdCardInlineToggleStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource BirdCardFieldLabelStyle}"
                        Text="{loc:Loc Key=AddBird.DescriptionLabel}" />
                    <TextBlock
                        Grid.Column="1"
                        MaxWidth="280"
                        Text="{Binding ElementName=DescriptionField, Path=(Validation.Errors)[0].ErrorContent}">
                        <TextBlock.Style>
                            <Style
                                BasedOn="{StaticResource BirdCardInlineErrorStyle}"
                                TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=DescriptionField, Path=(Validation.HasError)}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBox
                    x:Name="DescriptionField"
                    Grid.Row="1"
                    MaxLength="200"
                    Style="{StaticResource BirdCardTextBoxStyle}"
                    Text="{Binding Description,
                                   Mode=TwoWay,
                                   UpdateSourceTrigger=PropertyChanged,
                                   ValidatesOnNotifyDataErrors=True}"
                    Validation.ErrorTemplate="{StaticResource NoErrorTemplate}" />
            </Grid>

            <Border
                Grid.Row="2"
                Margin="0,10,0,0"
                Padding="12,8"
                Background="{DynamicResource ThemeInsetBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        Margin="0,0,12,0">
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.ArrivalMeta}" />
                        <DatePicker
                            Width="136"
                            helpers:ValidationPlacement.MaxErrorWidth="160"
                            helpers:ValidationPlacement.Placement="Bottom"
                            CalendarStyle="{DynamicResource DarkCalendarStyle}"
                            SelectedDate="{Binding Arrival,
                                                   Mode=TwoWay,
                                                   Converter={StaticResource DateOnlyConverter},
                                                   UpdateSourceTrigger=PropertyChanged,
                                                   ValidatesOnNotifyDataErrors=True}"
                            Style="{StaticResource BirdCardDatePickerStyle}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <Grid
                        Grid.Column="2"
                        Margin="12,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Style="{StaticResource BirdCardFieldLabelStyle}"
                                Text="{loc:Loc Key=Bird.DepartureMeta}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <DatePicker
                                x:Name="DepartureField"
                                Grid.Column="0"
                                Width="136"
                                CalendarStyle="{DynamicResource DarkCalendarStyle}"
                                SelectedDate="{Binding Departure,
                                                       Mode=TwoWay,
                                                       Converter={StaticResource DateOnlyConverter},
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                Style="{StaticResource BirdCardDatePickerStyle}"
                                Validation.ErrorTemplate="{StaticResource NoErrorTemplate}" />

                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding ClearDepartureCommand}"
                                Content="&#xE711;"
                                Style="{StaticResource BirdCardRoundIconButtonStyle}"
                                Visibility="{Binding Departure,
                                                     Converter={StaticResource NullToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Column="2"
                                MaxWidth="220"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                TextAlignment="Left"
                                TextWrapping="Wrap"
                                Text="{Binding ElementName=DepartureField, Path=(Validation.Errors)[0].ErrorContent}">
                                <TextBlock.Style>
                                    <Style
                                        BasedOn="{StaticResource BirdCardInlineErrorStyle}"
                                        TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                        <Setter Property="TextTrimming" Value="None" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=DepartureField, Path=(Validation.HasError)}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <Border
                        Grid.Column="3"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <ContentPresenter
                        Grid.Column="5"
                        Margin="16,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource EditButtonsTemplate}" />
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
