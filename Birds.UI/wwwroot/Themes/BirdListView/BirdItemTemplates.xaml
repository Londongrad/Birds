<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Birds.UI.Views.Helpers"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization"
    xmlns:local="clr-namespace:Birds.UI.Views.UserControls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Birds.UI;component/wwwroot/Themes/BirdListView/BirdItemCardResources.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="BirdViewTemplate">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Left"
                Style="{StaticResource BirdCardTitleTextStyle}"
                Text="{Binding DisplayName}" />

            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                ToolTip="{Binding Description}">
                <TextBlock.Style>
                    <Style BasedOn="{StaticResource BirdCardDescriptionTextStyle}" TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding Description}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Description}" Value="">
                                <Setter Property="Text" Value="{loc:Loc Key=Bird.NoDescription}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                <Setter Property="Text" Value="{loc:Loc Key=Bird.NoDescription}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border
                Grid.Row="2"
                Margin="0,14,0,0"
                Padding="12,9"
                Background="{DynamicResource ThemeInsetBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.ArrivalMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding ArrivalDisplay}" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.DepartureMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding DepartureDisplay}" />
                        </StackPanel>

                        <Border
                            Grid.Column="3"
                            Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                        <StackPanel
                            Grid.Column="4"
                            MinWidth="88">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.DurationMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding DurationDisplay}" />
                        </StackPanel>
                    </Grid>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <Grid Grid.Column="2">
                        <ContentPresenter
                            x:Name="NormalButtons"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource NormalButtonsTemplate}">
                            <ContentPresenter.Visibility>
                                <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                    <Binding Path="IsConfirmingDelete" />
                                    <Binding Path="IsEditing" />
                                </MultiBinding>
                            </ContentPresenter.Visibility>
                        </ContentPresenter>

                        <ContentPresenter
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ConfirmButtonsTemplate}"
                            Visibility="{Binding IsConfirmingDelete,
                                                 Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="BirdEditTemplate">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Column="0"
                    Margin="0,0,16,0"
                    VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemeMutedTextBrush}"
                        Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:BirdItemControl}},
                                       Path=DisplayIndex}" />

                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=AddBird.SpeciesLabel}" />
                        <TextBlock
                            Grid.Column="1"
                            MaxWidth="180"
                            Text="{Binding ElementName=SpeciesField, Path=(Validation.Errors)[0].ErrorContent}">
                            <TextBlock.Style>
                                <Style
                                    BasedOn="{StaticResource BirdCardInlineErrorStyle}"
                                    TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding ElementName=SpeciesField, Path=(Validation.HasError)}"
                                            Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox
                        x:Name="SpeciesField"
                        Grid.Row="2"
                        IsEditable="False"
                        ItemTemplate="{StaticResource BirdNameComboTemplate}"
                        ItemsSource="{Binding BirdNames}"
                        SelectedItem="{Binding SelectedBirdName,
                                               Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged,
                                               ValidatesOnNotifyDataErrors=True}"
                        Style="{StaticResource BirdCardComboBoxStyle}"
                        Validation.ErrorTemplate="{StaticResource NoErrorTemplate}"
                        Width="280" />
                </Grid>

                <Border
                    Grid.Column="2"
                    Width="144"
                    Padding="12,8"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource ThemeInsetBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.StatusLabel}" />
                        <CheckBox
                            Content="{Binding StatusText}"
                            IsChecked="{Binding IsAlive,
                                                Mode=TwoWay}"
                            Style="{StaticResource BirdCardInlineToggleStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource BirdCardFieldLabelStyle}"
                        Text="{loc:Loc Key=AddBird.DescriptionLabel}" />
                    <TextBlock
                        Grid.Column="1"
                        MaxWidth="280"
                        Text="{Binding ElementName=DescriptionField, Path=(Validation.Errors)[0].ErrorContent}">
                        <TextBlock.Style>
                            <Style
                                BasedOn="{StaticResource BirdCardInlineErrorStyle}"
                                TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding ElementName=DescriptionField, Path=(Validation.HasError)}"
                                        Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBox
                    x:Name="DescriptionField"
                    Grid.Row="1"
                    MaxLength="200"
                    Style="{StaticResource BirdCardTextBoxStyle}"
                    Text="{Binding Description,
                                   Mode=TwoWay,
                                   UpdateSourceTrigger=PropertyChanged,
                                   ValidatesOnNotifyDataErrors=True}"
                    Validation.ErrorTemplate="{StaticResource NoErrorTemplate}" />
            </Grid>

            <Border
                Grid.Row="2"
                Margin="0,10,0,0"
                Padding="12,8"
                Background="{DynamicResource ThemeInsetBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        Margin="0,0,12,0">
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.ArrivalMeta}" />
                        <DatePicker
                            Width="136"
                            helpers:ValidationPlacement.MaxErrorWidth="160"
                            helpers:ValidationPlacement.Placement="Bottom"
                            CalendarStyle="{DynamicResource DarkCalendarStyle}"
                            SelectedDate="{Binding Arrival,
                                                   Mode=TwoWay,
                                                   Converter={StaticResource DateOnlyConverter},
                                                   UpdateSourceTrigger=PropertyChanged,
                                                   ValidatesOnNotifyDataErrors=True}"
                            Style="{StaticResource BirdCardDatePickerStyle}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <Grid
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Style="{StaticResource BirdCardFieldLabelStyle}"
                                Text="{loc:Loc Key=Bird.DepartureMeta}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <DatePicker
                                x:Name="DepartureField"
                                Grid.Column="0"
                                Width="136"
                                CalendarStyle="{DynamicResource DarkCalendarStyle}"
                                SelectedDate="{Binding Departure,
                                                       Mode=TwoWay,
                                                       Converter={StaticResource DateOnlyConverter},
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                Style="{StaticResource BirdCardDatePickerStyle}"
                                Validation.ErrorTemplate="{StaticResource NoErrorTemplate}" />

                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding ClearDepartureCommand}"
                                Content="&#xE711;"
                                Style="{StaticResource BirdCardRoundIconButtonStyle}"
                                Visibility="{Binding Departure,
                                                     Converter={StaticResource NullToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch"
                                TextAlignment="Left"
                                TextWrapping="NoWrap"
                                TextTrimming="CharacterEllipsis"
                                ToolTip="{Binding ElementName=DepartureField, Path=(Validation.Errors)[0].ErrorContent}"
                                Text="{Binding ElementName=DepartureField, Path=(Validation.Errors)[0].ErrorContent}">
                                <TextBlock.Style>
                                    <Style
                                        BasedOn="{StaticResource BirdCardInlineErrorStyle}"
                                        TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding ElementName=DepartureField, Path=(Validation.HasError)}"
                                                Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <Border
                        Grid.Column="3"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <ContentPresenter
                        Grid.Column="4"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource EditButtonsTemplate}" />
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>