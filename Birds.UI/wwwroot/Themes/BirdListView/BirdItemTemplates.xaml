<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Birds.UI.Views.Helpers"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization">

    <DataTemplate x:Key="BirdNameComboTemplate">
        <TextBlock
            FontSize="16"
            Foreground="{DynamicResource ThemePrimaryTextBrush}"
            Text="{Binding Converter={StaticResource BirdNameDisplayConverter}}" />
    </DataTemplate>

    <Style
        x:Key="BirdCardTitleTextStyle"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style
        x:Key="BirdCardDescriptionTextStyle"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style
        x:Key="BirdCardMetaLabelStyle"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
    </Style>

    <Style
        x:Key="BirdCardMetaValueStyle"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
    </Style>

    <Style
        x:Key="BirdCardMetaChipStyle"
        TargetType="Border">
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Background" Value="{DynamicResource ThemeInsetBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style
        x:Key="BirdCardMetaSeparatorStyle"
        TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="14,4" />
        <Setter Property="Background" Value="{DynamicResource ThemeCardBorderBrush}" />
        <Setter Property="Opacity" Value="0.75" />
    </Style>

    <Style
        x:Key="BirdCardFieldLabelStyle"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
    </Style>

    <Style
        x:Key="BirdCardComboBoxStyle"
        BasedOn="{StaticResource ComboBox}"
        TargetType="ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="14,0,38,0" />
        <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style
        x:Key="BirdCardTextBoxStyle"
        BasedOn="{StaticResource TextBoxAdd}"
        TargetType="TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinHeight" Value="112" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style
        x:Key="BirdCardDatePickerStyle"
        BasedOn="{StaticResource DatePickerAdd}"
        TargetType="DatePicker">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style
        x:Key="BirdCardInlineToggleStyle"
        TargetType="CheckBox">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            x:Name="Track"
                            Width="40"
                            Height="22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{DynamicResource ThemeToggleTrackOffBrush}"
                            BorderBrush="{DynamicResource ThemeToggleBorderOffBrush}"
                            BorderThickness="1"
                            CornerRadius="11" />

                        <Ellipse
                            x:Name="Thumb"
                            Width="16"
                            Height="16"
                            Margin="3,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource ThemePrimaryTextBrush}"
                            StrokeThickness="0" />

                        <ContentPresenter
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            RecognizesAccessKey="True" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeToggleTrackOnBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeToggleBorderOnBrush}" />
                            <Setter TargetName="Thumb" Property="Margin" Value="21,0,0,0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="BirdViewTemplate">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Style="{StaticResource BirdCardTitleTextStyle}"
                    Text="{Binding DisplayName}" />

                <Border
                    Grid.Column="1"
                    Padding="10,5"
                    VerticalAlignment="Center"
                    CornerRadius="999">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ThemeStatusAliveBackgroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
                                    <Setter Property="Background" Value="{DynamicResource ThemeStatusDeadBackgroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                        Text="{Binding StatusText}" />
                </Border>
            </Grid>

            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                ToolTip="{Binding Description}">
                <TextBlock.Style>
                    <Style BasedOn="{StaticResource BirdCardDescriptionTextStyle}" TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding Description}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Description}" Value="">
                                <Setter Property="Text" Value="{loc:Loc Key=Bird.NoDescription}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                <Setter Property="Text" Value="{loc:Loc Key=Bird.NoDescription}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border
                Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14,10"
                Background="{DynamicResource ThemeInsetBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.ArrivalMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding ArrivalDisplay}" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.DepartureMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding DepartureDisplay}" />
                        </StackPanel>

                        <Border
                            Grid.Column="3"
                            Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                        <StackPanel
                            Grid.Column="4"
                            MinWidth="112">
                            <TextBlock
                                Style="{StaticResource BirdCardMetaLabelStyle}"
                                Text="{loc:Loc Key=Bird.DurationMeta}" />
                            <TextBlock
                                Style="{StaticResource BirdCardMetaValueStyle}"
                                Text="{Binding DurationDisplay}" />
                        </StackPanel>
                    </Grid>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <Grid Grid.Column="2">
                        <ContentPresenter
                            x:Name="NormalButtons"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource NormalButtonsTemplate}">
                            <ContentPresenter.Visibility>
                                <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                    <Binding Path="IsConfirmingDelete" />
                                    <Binding Path="IsEditing" />
                                </MultiBinding>
                            </ContentPresenter.Visibility>
                        </ContentPresenter>

                        <ContentPresenter
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ConfirmButtonsTemplate}"
                            Visibility="{Binding IsConfirmingDelete,
                                                 Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="BirdEditTemplate">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="196" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,18,0">
                    <TextBlock
                        Style="{StaticResource BirdCardFieldLabelStyle}"
                        Text="{loc:Loc Key=AddBird.SpeciesLabel}" />
                    <ComboBox
                        IsEditable="False"
                        ItemTemplate="{StaticResource BirdNameComboTemplate}"
                        ItemsSource="{Binding BirdNames}"
                        SelectedItem="{Binding SelectedBirdName,
                                               Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged,
                                               ValidatesOnNotifyDataErrors=True}"
                        Style="{StaticResource BirdCardComboBoxStyle}" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    MinHeight="74"
                    Padding="14,12"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource ThemeInsetBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.StatusLabel}" />
                        <CheckBox
                            Content="{Binding StatusText}"
                            IsChecked="{Binding IsAlive,
                                                Mode=TwoWay}"
                            Style="{StaticResource BirdCardInlineToggleStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock
                    Style="{StaticResource BirdCardFieldLabelStyle}"
                    Text="{loc:Loc Key=AddBird.DescriptionLabel}" />
                <TextBox
                    Style="{StaticResource BirdCardTextBoxStyle}"
                    Text="{Binding Description,
                                   Mode=TwoWay,
                                   UpdateSourceTrigger=PropertyChanged,
                                   ValidatesOnNotifyDataErrors=True}" />
            </StackPanel>

            <Border
                Grid.Row="2"
                Margin="0,16,0,0"
                Padding="14,12"
                Background="{DynamicResource ThemeInsetBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeFieldBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.ArrivalMeta}" />
                        <DatePicker
                            helpers:ValidationPlacement.MaxErrorWidth="160"
                            helpers:ValidationPlacement.Placement="Bottom"
                            CalendarStyle="{DynamicResource DarkCalendarStyle}"
                            SelectedDate="{Binding Arrival,
                                                   Mode=TwoWay,
                                                   Converter={StaticResource DateOnlyConverter},
                                                   UpdateSourceTrigger=PropertyChanged,
                                                   ValidatesOnNotifyDataErrors=True}"
                            Style="{StaticResource BirdCardDatePickerStyle}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Style="{StaticResource BirdCardFieldLabelStyle}"
                            Text="{loc:Loc Key=Bird.DepartureMeta}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <DatePicker
                                Grid.Column="0"
                                helpers:ValidationPlacement.MaxErrorWidth="160"
                                helpers:ValidationPlacement.Placement="Bottom"
                                CalendarStyle="{DynamicResource DarkCalendarStyle}"
                                SelectedDate="{Binding Departure,
                                                       Mode=TwoWay,
                                                       Converter={StaticResource DateOnlyConverter},
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                Style="{StaticResource BirdCardDatePickerStyle}" />

                            <Button
                                Grid.Column="1"
                                Width="30"
                                Height="30"
                                Margin="8,7,0,0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{DynamicResource ThemeNotificationActionBrush}"
                                BorderBrush="{DynamicResource ThemeCardBorderBrush}"
                                BorderThickness="1"
                                Command="{Binding ClearDepartureCommand}"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10"
                                Foreground="{DynamicResource ThemeMutedTextBrush}"
                                Visibility="{Binding Departure,
                                                     Converter={StaticResource NullToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <Border
                        Grid.Column="3"
                        Style="{StaticResource BirdCardMetaSeparatorStyle}" />

                    <ContentPresenter
                        Grid.Column="4"
                        Margin="14,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource EditButtonsTemplate}" />
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
