<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ScrollTrackBrush" Color="#19212B" />
    <SolidColorBrush x:Key="ScrollTrackHoverBrush" Color="#202A36" />
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#586779" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#6B7D92" />
    <SolidColorBrush x:Key="ScrollThumbDraggingBrush" Color="#88A0BC" />

    <Style
        x:Key="MinimalThumbStyle"
        TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border
                        x:Name="ThumbBody"
                        Margin="1"
                        Background="{StaticResource ScrollThumbBrush}"
                        CornerRadius="5"
                        SnapsToDevicePixels="True" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background"
                                    Value="{StaticResource ScrollThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background"
                                    Value="{StaticResource ScrollThumbDraggingBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="MinHeight" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border
                        x:Name="TrackBackground"
                        Margin="1"
                        Background="{StaticResource ScrollTrackBrush}"
                        CornerRadius="5">
                        <Track
                            x:Name="PART_Track"
                            IsDirectionReversed="True"
                            Orientation="{TemplateBinding Orientation}"
                            SnapsToDevicePixels="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton
                                    Background="Transparent"
                                    BorderThickness="0"
                                    IsTabStop="False"
                                    Opacity="0" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MinimalThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton
                                    Background="Transparent"
                                    BorderThickness="0"
                                    IsTabStop="False"
                                    Opacity="0" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True" />
                            <Setter Property="Width" Value="12" />
                            <Setter Property="Height" Value="Auto" />
                        </Trigger>

                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            <Setter Property="Height" Value="12" />
                            <Setter Property="Width" Value="Auto" />
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TrackBackground" Property="Background"
                                    Value="{StaticResource ScrollTrackHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Focusable" Value="False" />
    </Style>
</ResourceDictionary>