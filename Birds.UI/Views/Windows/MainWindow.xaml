<Window
    x:Class="Birds.UI.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notify="clr-namespace:Birds.UI.Services.Notification"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:sync="clr-namespace:Birds.Shared.Sync;assembly=Birds.Shared"
    xmlns:vm="clr-namespace:Birds.UI.ViewModels"
    Title="{loc:Loc Key=Main.Header.Default.Title}"
    Width="1360"
    Height="840"
    MinWidth="1080"
    MinHeight="700"
    Background="{DynamicResource ThemeWindowBackgroundBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    mc:Ignorable="d">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTitleBarForegroundBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="NotificationCenterButtonStyle"
            BasedOn="{StaticResource TitleBarButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonPressedBrush}" />
                            </Trigger>
                            <DataTrigger
                                Binding="{Binding DataContext.IsNotificationCenterOpen, RelativeSource={RelativeSource AncestorType=Window}}"
                                Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding DataContext.ShouldShowNotificationBadge, RelativeSource={RelativeSource AncestorType=Window}}"
                                Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CloseTitleBarButtonStyle"
            BasedOn="{StaticResource TitleBarButtonStyle}"
            TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeCloseHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeClosePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DrawerActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeAccentButtonHoverBrush}" />
                                <Setter TargetName="ButtonSurface" Property="BorderBrush"
                                        Value="{DynamicResource ThemeAccentButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NotificationDismissButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeTitleBarButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickOperationIndicatorStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeShellBorderBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecentOperationSuccess}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeStatusAliveBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRecentOperationError}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeStatusDeadBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuickOperationPulseStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecentOperationSuccess}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRecentOperationError}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PendingUndoButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,7,12,9" />
            <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background"
                                        Value="{DynamicResource ThemeNotificationCardHoverBrush}" />
                                <Setter TargetName="ButtonSurface" Property="BorderBrush"
                                        Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemoteSyncStatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Opacity" Value="0.94" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShouldShowRemoteSyncStatus}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}"
                             Value="{x:Static sync:RemoteSyncDisplayState.Syncing}">
                    <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBadgeBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Synced}">
                    <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Paused}">
                    <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}"
                             Value="{x:Static sync:RemoteSyncDisplayState.Offline}">
                    <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Error}">
                    <Setter Property="Background" Value="{DynamicResource ThemeNotificationActionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RemoteSyncStatusDotStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="{DynamicResource ThemeSecondaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RemoteSyncStatus}"
                             Value="{x:Static sync:RemoteSyncDisplayState.Syncing}">
                    <Setter Property="Fill" Value="{DynamicResource ThemeBadgeBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Synced}">
                    <Setter Property="Fill" Value="{DynamicResource ThemeStatusAliveBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Paused}">
                    <Setter Property="Fill" Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}"
                             Value="{x:Static sync:RemoteSyncDisplayState.Offline}">
                    <Setter Property="Fill" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Error}">
                    <Setter Property="Fill" Value="{DynamicResource ThemeStatusDeadBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border
        Background="{DynamicResource ThemeWindowBackgroundBrush}"
        BorderBrush="{DynamicResource ThemeShellBorderBrush}"
        BorderThickness="1">
        <Grid Background="{DynamicResource ThemeWindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="{DynamicResource ThemeChromeBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeShellBorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="16"
                        Height="16"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ThemeTitleBarIconBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeTitleBarIconBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="9"
                            Foreground="{DynamicResource ThemeTitleBarIconForegroundBrush}"
                            Text="B" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Grid
                            x:Name="PendingDeleteUndoHost"
                            Margin="0,0,8,0"
                            Visibility="Collapsed">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.86" ScaleY="0.86" />
                                    <TranslateTransform Y="-2" />
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Button
                                x:Name="PendingDeleteUndoButton"
                                Command="{Binding UndoPendingDeleteCommand}"
                                Style="{StaticResource PendingUndoButtonStyle}"
                                ToolTip="{Binding PendingDeleteUndoToolTip}">
                                <StackPanel Orientation="Horizontal">
                                    <Path
                                        Width="11"
                                        Height="11"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Data="M 2 3.5 A 4.5 4.5 0 1 1 4.2 8 M 2.2 1.2 L 2.2 4.4 L 5.2 4.4"
                                        Stroke="{DynamicResource ThemePrimaryTextBrush}"
                                        StrokeThickness="1.5"
                                        StrokeStartLineCap="Round"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        Text="{loc:Loc Key=Notification.UndoDelete}" />
                                </StackPanel>
                            </Button>
                            <Border
                                x:Name="PendingDeleteUndoProgressBar"
                                Height="2.5"
                                Margin="1,0,1,1"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch"
                                CornerRadius="0,0,11,11"
                                Opacity="0.9"
                                RenderTransformOrigin="0,0.5">
                                <Border.Background>
                                    <SolidColorBrush x:Name="PendingDeleteUndoProgressBrush" Color="#7CE38B" />
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>

                        <Border
                            Style="{StaticResource RemoteSyncStatusPillStyle}"
                            ToolTip="{Binding RemoteSyncStatusHint}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    Width="5"
                                    Height="5"
                                    Margin="0,0,7,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource RemoteSyncStatusDotStyle}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                    Text="{Binding RemoteSyncStatusLabel}" />
                            </StackPanel>
                        </Border>

                        <Border
                            x:Name="QuickOperationIndicator"
                            Width="20"
                            Height="20"
                            Margin="0,0,8,0"
                            BorderThickness="1"
                            CornerRadius="10"
                            ToolTip="{Binding RecentOperationStatusToolTip}"
                            Visibility="Collapsed"
                            Style="{StaticResource QuickOperationIndicatorStyle}">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                                    <TranslateTransform Y="-3" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Grid>
                                <Border
                                    x:Name="QuickOperationPulse"
                                    Margin="-2"
                                    Style="{StaticResource QuickOperationPulseStyle}">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
                                    </Border.RenderTransform>
                                </Border>
                                <Path
                                    Width="9"
                                    Height="7"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="M 1 4 L 3.4 6.2 L 8 1.4"
                                    Stroke="{DynamicResource ThemeStatusAliveBrush}"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    StrokeThickness="1.8"
                                    Visibility="{Binding IsRecentOperationSuccess, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Path
                                    Width="8"
                                    Height="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="M 1 1 L 7 7 M 7 1 L 1 7"
                                    Stroke="{DynamicResource ThemeStatusDeadBrush}"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeThickness="1.6"
                                    Visibility="{Binding IsRecentOperationError, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Border>

                        <Button
                            Command="{Binding ToggleNotificationCenterCommand}"
                            Margin="0"
                            Style="{StaticResource NotificationCenterButtonStyle}">
                            <Grid
                                Width="18"
                                Height="18"
                                ClipToBounds="False">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="14"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    Text="&#xE7F4;" />
                                <Border
                                    Width="16"
                                    Height="16"
                                    Margin="0,-6,-7,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource ThemeBadgeBrush}"
                                    BorderBrush="{DynamicResource ThemeChromeBackgroundBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding ShouldShowNotificationBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="9"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                        Text="{Binding UnreadNotificationCount, Mode=OneWay}" />
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Click="OnMinimizeClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="10"
                                Height="10"
                                SnapsToDevicePixels="True">
                                <Border
                                    Height="1.4"
                                    VerticalAlignment="Center"
                                    Background="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            </Grid>
                        </Button>

                        <Button
                            Click="OnMaximizeRestoreClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="12"
                                Height="12"
                                SnapsToDevicePixels="True">
                                <Rectangle
                                    x:Name="MaximizeGlyph"
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeThickness="1.2" />
                                <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        Margin="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                </Grid>
                            </Grid>
                        </Button>

                        <Button
                            Click="OnCloseClick"
                            Style="{StaticResource CloseTitleBarButtonStyle}">
                            <Grid
                                Width="11"
                                Height="11"
                                SnapsToDevicePixels="True">
                                <Path
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeThickness="1.5"
                                    Data="M 1 1 L 10 10 M 10 1 L 1 10" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{DynamicResource ThemeSidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeShellBorderBrush}"
                    BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="24,24,24,20">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="26"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                Text="Birds" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Margin="14,0,14,0"
                            VerticalAlignment="Center">
                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:AddBirdViewModel}"
                                IsChecked="True"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="{loc:Loc Key=Nav.AddBird}" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdListViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="{loc:Loc Key=Nav.Archive}" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdStatisticsViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="{loc:Loc Key=Nav.Statistics}" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:SettingsViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="{loc:Loc Key=Nav.Settings}" />
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Margin="28,26,28,0"
                        MaxWidth="760"
                        HorizontalAlignment="Center"
                        Padding="0,0,0,18"
                        BorderBrush="{DynamicResource ThemeShellBorderBrush}"
                        BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowContentHeader}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                Text="{Binding HeaderTitle}" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="14"
                                Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                                Text="{Binding HeaderSubtitle}" />
                        </StackPanel>
                    </Border>

                    <ContentControl
                        Grid.Row="1"
                        Margin="24"
                        Content="{Binding Path=Navigation.Current}" />

                    <Border
                        x:Name="NotificationCenterPanel"
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        Width="336"
                        Margin="0,18,24,24"
                        Background="{DynamicResource ThemeNotificationPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeNotificationPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Visibility="{Binding IsNotificationCenterOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                Padding="18,18,18,14"
                                BorderBrush="{DynamicResource ThemeNotificationPanelBorderBrush}"
                                BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                            Text="{loc:Loc Key=Notification.CenterTitle}" />
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource ThemeSecondaryTextBrush}">
                                            <Run Text="{loc:Loc Key=Notification.UnreadLabel}" />
                                            <Run Text="{Binding UnreadNotificationCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding ClearNotificationsCommand}"
                                        IsEnabled="{Binding HasNotifications}"
                                        Style="{StaticResource DrawerActionButtonStyle}">
                                        <TextBlock Text="{loc:Loc Key=Notification.Clear}" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <Border
                                    Padding="26"
                                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityInverse}}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                            Text="{loc:Loc Key=Notification.EmptyTitle}" />
                                        <TextBlock
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            FontSize="13"
                                            Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                                            Text="{loc:Loc Key=Notification.EmptyDescription}" />
                                    </StackPanel>
                                </Border>

                                <ScrollViewer
                                    Padding="14"
                                    VerticalScrollBarVisibility="Auto"
                                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding Notifications}">
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Margin" Value="0,0,0,12" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type notify:NotificationToast}">
                                                <Border
                                                    x:Name="NotificationCard"
                                                    Background="{DynamicResource ThemeNotificationCardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource ThemeNotificationCardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                    <Grid ClipToBounds="True">
                                                        <Border
                                                            x:Name="NotificationAccent"
                                                            Width="4"
                                                            HorizontalAlignment="Left"
                                                            Background="{DynamicResource ThemeFieldBorderFocusBrush}"
                                                            CornerRadius="16,0,0,16" />

                                                        <Grid Margin="16,14,14,14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock
                                                                x:Name="NotificationTitle"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                                Text="{Binding Title}"
                                                                TextWrapping="Wrap" />

                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Margin="12,0,0,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                Foreground="{DynamicResource ThemeMutedTextBrush}"
                                                                Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" />

                                                            <Button
                                                                Grid.Column="2"
                                                                Command="{Binding DataContext.DismissNotificationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource NotificationDismissButtonStyle}">
                                                                <Path
                                                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                                    StrokeEndLineCap="Round"
                                                                    StrokeStartLineCap="Round"
                                                                    StrokeThickness="1.4"
                                                                    Data="M 1 1 L 9 9 M 9 1 L 1 9" />
                                                            </Button>

                                                            <TextBlock
                                                                Grid.Row="1"
                                                                Grid.ColumnSpan="3"
                                                                Margin="0,10,0,0"
                                                                FontSize="13"
                                                                Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                                                                LineHeight="19"
                                                                Text="{Binding Message}"
                                                                TextWrapping="Wrap" />

                                                            <StackPanel
                                                                Grid.Row="2"
                                                                Grid.ColumnSpan="3"
                                                                Margin="0,12,0,0"
                                                                Orientation="Horizontal">
                                                                <Border
                                                                    x:Name="NotificationTypePill"
                                                                    Margin="0,0,8,0"
                                                                    Padding="8,3"
                                                                    Background="{DynamicResource ThemeNotificationActionBrush}"
                                                                    CornerRadius="10">
                                                                    <TextBlock
                                                                        x:Name="NotificationTypeText"
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                                        Text="{Binding TypeLabel}" />
                                                                </Border>

                                                                <Border
                                                                    Background="{DynamicResource ThemeNotificationActionBrush}"
                                                                    CornerRadius="10"
                                                                    Padding="8,3"
                                                                    Visibility="{Binding IsRead, Converter={StaticResource BoolToVisibilityInverse}}">
                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                                                                        Text="{loc:Loc Key=Notification.New}" />
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger SourceName="NotificationCard" Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="NotificationCard" Property="Background"
                                                                Value="{DynamicResource ThemeNotificationCardHoverBrush}" />
                                                        <Setter TargetName="NotificationCard" Property="BorderBrush"
                                                                Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                        <Setter TargetName="NotificationCard" Property="BorderBrush"
                                                                Value="{DynamicResource ThemeNotificationUnreadBorderBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}"
                                                                 Value="{x:Static notify:NotificationType.Success}">
                                                        <Setter TargetName="NotificationAccent" Property="Background"
                                                                Value="#48A975" />
                                                        <Setter TargetName="NotificationTypePill" Property="Background"
                                                                Value="#163124" />
                                                        <Setter TargetName="NotificationTypeText" Property="Foreground"
                                                                Value="#BCEFCF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}"
                                                                 Value="{x:Static notify:NotificationType.Warning}">
                                                        <Setter TargetName="NotificationAccent" Property="Background"
                                                                Value="#D38E4A" />
                                                        <Setter TargetName="NotificationTypePill" Property="Background"
                                                                Value="#392615" />
                                                        <Setter TargetName="NotificationTypeText" Property="Foreground"
                                                                Value="#FFD6A5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}"
                                                                 Value="{x:Static notify:NotificationType.Error}">
                                                        <Setter TargetName="NotificationAccent" Property="Background"
                                                                Value="#C76363" />
                                                        <Setter TargetName="NotificationTypePill" Property="Background"
                                                                Value="#3B1C1C" />
                                                        <Setter TargetName="NotificationTypeText" Property="Foreground"
                                                                Value="#FFC4C4" />
                                                        <Setter TargetName="NotificationTitle" Property="Foreground"
                                                                Value="#FFF0F0" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>