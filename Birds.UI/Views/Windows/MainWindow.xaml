<Window
    x:Class="Birds.UI.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:Birds.UI.ViewModels"
    Title="Birds"
    Width="1360"
    Height="840"
    MinWidth="1080"
    MinHeight="700"
    Background="#161A20"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    mc:Ignorable="d">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#C8D0DA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#202733" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#2B3442" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CloseTitleBarButtonStyle"
            BasedOn="{StaticResource TitleBarButtonStyle}"
            TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#B24A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#943C3C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="#161A20"
        BorderBrush="#252B33"
        BorderThickness="1">
        <Grid Background="#161A20">
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#0F1318"
                BorderBrush="#252B33"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="16"
                        Height="16"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="#202733"
                        BorderBrush="#2C3642"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="9"
                            Foreground="#DDE4EC"
                            Text="B" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Click="OnMinimizeClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="10"
                                Height="10"
                                SnapsToDevicePixels="True">
                                <Border
                                    Height="1.4"
                                    VerticalAlignment="Center"
                                    Background="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            </Grid>
                        </Button>

                        <Button
                            Click="OnMaximizeRestoreClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="12"
                                Height="12"
                                SnapsToDevicePixels="True">
                                <Rectangle
                                    x:Name="MaximizeGlyph"
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeThickness="1.2" />
                                <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        Margin="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                </Grid>
                            </Grid>
                        </Button>

                        <Button
                            Click="OnCloseClick"
                            Style="{StaticResource CloseTitleBarButtonStyle}">
                            <Grid
                                Width="11"
                                Height="11"
                                SnapsToDevicePixels="True">
                                <Path
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeThickness="1.5"
                                    Data="M 1 1 L 10 10 M 10 1 L 1 10" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="#101318"
                    BorderBrush="#252B33"
                    BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="24,24,24,20">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="26"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Birds" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Margin="14,0,14,0"
                            VerticalAlignment="Center">
                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:AddBirdViewModel}"
                                IsChecked="True"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Добавить птицу" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdListViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Архив" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdStatisticsViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Статистика" />
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Margin="28,26,28,0"
                        Width="760"
                        MaxWidth="760"
                        HorizontalAlignment="Center"
                        Padding="0,0,0,18"
                        BorderBrush="#252B33"
                        BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HeaderTitle}" Value="Добавление птицы">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding HeaderTitle}" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="14"
                                Foreground="#8E98A6"
                                Text="{Binding HeaderSubtitle}" />
                        </StackPanel>
                    </Border>

                    <ContentControl
                        Grid.Row="1"
                        Margin="24"
                        Content="{Binding Path=Navigation.Current}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
