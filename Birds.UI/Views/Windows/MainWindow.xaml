<Window
    x:Class="Birds.UI.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notify="clr-namespace:Birds.UI.Services.Notification"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:Birds.UI.ViewModels"
    Title="Birds"
    Width="1360"
    Height="840"
    MinWidth="1080"
    MinHeight="700"
    Background="#161A20"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    mc:Ignorable="d">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#C8D0DA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#202733" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#2B3442" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="NotificationCenterButtonStyle"
            BasedOn="{StaticResource TitleBarButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#202733" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#2B3442" />
                            </Trigger>
                            <DataTrigger
                                Binding="{Binding DataContext.IsNotificationCenterOpen, RelativeSource={RelativeSource AncestorType=Window}}"
                                Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#202733" />
                                <Setter Property="Foreground" Value="#EEF3F8" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding DataContext.ShouldShowNotificationBadge, RelativeSource={RelativeSource AncestorType=Window}}"
                                Value="True">
                                <Setter Property="Foreground" Value="#EEF5FD" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CloseTitleBarButtonStyle"
            BasedOn="{StaticResource TitleBarButtonStyle}"
            TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#B24A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#943C3C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DrawerActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#1B222C" />
            <Setter Property="BorderBrush" Value="#2B3542" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D8E1EB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#212936" />
                                <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="#3A4758" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#26303E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NotificationDismissButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#96A3B5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#202733" />
                                <Setter Property="Foreground" Value="#E6EEF7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#293240" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="#161A20"
        BorderBrush="#252B33"
        BorderThickness="1">
        <Grid Background="#161A20">
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#0F1318"
                BorderBrush="#252B33"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="16"
                        Height="16"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="#202733"
                        BorderBrush="#2C3642"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="9"
                            Foreground="#DDE4EC"
                            Text="B" />
                    </Border>

                    <Button
                        Grid.Column="1"
                        Command="{Binding ToggleNotificationCenterCommand}"
                        Style="{StaticResource NotificationCenterButtonStyle}">
                        <Grid
                            Width="18"
                            Height="18"
                            ClipToBounds="False">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                Text="&#xE7F4;" />
                            <Border
                                Width="16"
                                Height="16"
                                Margin="0,-6,-7,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#5D86C9"
                                BorderBrush="#0F1318"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding ShouldShowNotificationBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="9"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding UnreadNotificationCount, Mode=OneWay}" />
                            </Border>
                        </Grid>
                    </Button>

                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Click="OnMinimizeClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="10"
                                Height="10"
                                SnapsToDevicePixels="True">
                                <Border
                                    Height="1.4"
                                    VerticalAlignment="Center"
                                    Background="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            </Grid>
                        </Button>

                        <Button
                            Click="OnMaximizeRestoreClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="12"
                                Height="12"
                                SnapsToDevicePixels="True">
                                <Rectangle
                                    x:Name="MaximizeGlyph"
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeThickness="1.2" />
                                <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        Margin="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                </Grid>
                            </Grid>
                        </Button>

                        <Button
                            Click="OnCloseClick"
                            Style="{StaticResource CloseTitleBarButtonStyle}">
                            <Grid
                                Width="11"
                                Height="11"
                                SnapsToDevicePixels="True">
                                <Path
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeThickness="1.5"
                                    Data="M 1 1 L 10 10 M 10 1 L 1 10" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="#101318"
                    BorderBrush="#252B33"
                    BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="24,24,24,20">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="26"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Birds" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Margin="14,0,14,0"
                            VerticalAlignment="Center">
                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:AddBirdViewModel}"
                                IsChecked="True"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Добавить птицу" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdListViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Архив" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdStatisticsViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Статистика" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:SettingsViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Настройки" />
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Margin="28,26,28,0"
                        MaxWidth="760"
                        HorizontalAlignment="Center"
                        Padding="0,0,0,18"
                        BorderBrush="#252B33"
                        BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowContentHeader}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding HeaderTitle}" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="14"
                                Foreground="#8E98A6"
                                Text="{Binding HeaderSubtitle}" />
                        </StackPanel>
                    </Border>

                    <ContentControl
                        Grid.Row="1"
                        Margin="24"
                        Content="{Binding Path=Navigation.Current}" />

                    <Border
                        x:Name="NotificationCenterPanel"
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        Width="336"
                        Margin="0,18,24,24"
                        Background="#10151B"
                        BorderBrush="#252D37"
                        BorderThickness="1"
                        CornerRadius="20"
                        Visibility="{Binding IsNotificationCenterOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                Padding="18,18,18,14"
                                BorderBrush="#252D37"
                                BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="Уведомления" />
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="12"
                                            Foreground="#8E98A6">
                                            <Run Text="Непрочитано: " />
                                            <Run Text="{Binding UnreadNotificationCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding ClearNotificationsCommand}"
                                        IsEnabled="{Binding HasNotifications}"
                                        Style="{StaticResource DrawerActionButtonStyle}">
                                        <TextBlock Text="Очистить" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <Border
                                    Padding="26"
                                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityInverse}}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="Пока пусто" />
                                        <TextBlock
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            FontSize="13"
                                            Foreground="#8E98A6"
                                            Text="Здесь будет история действий и важных сообщений приложения." />
                                    </StackPanel>
                                </Border>

                                <ScrollViewer
                                    Padding="14"
                                    VerticalScrollBarVisibility="Auto"
                                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding Notifications}">
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Margin" Value="0,0,0,12" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type notify:NotificationToast}">
                                                <Border
                                                    x:Name="NotificationCard"
                                                    Background="#161C24"
                                                    BorderBrush="#2B3541"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                    <Grid ClipToBounds="True">
                                                        <Border
                                                            x:Name="NotificationAccent"
                                                            Width="4"
                                                            HorizontalAlignment="Left"
                                                            Background="#6C7A8D"
                                                            CornerRadius="16,0,0,16" />

                                                        <Grid Margin="16,14,14,14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock
                                                                x:Name="NotificationTitle"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="#F3F6FA"
                                                                Text="{Binding Title}"
                                                                TextWrapping="Wrap" />

                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Margin="12,0,0,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                Foreground="#7F8A98"
                                                                Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" />

                                                            <Button
                                                                Grid.Column="2"
                                                                Command="{Binding DataContext.DismissNotificationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource NotificationDismissButtonStyle}">
                                                                <Path
                                                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                                    StrokeEndLineCap="Round"
                                                                    StrokeStartLineCap="Round"
                                                                    StrokeThickness="1.4"
                                                                    Data="M 1 1 L 9 9 M 9 1 L 1 9" />
                                                            </Button>

                                                            <TextBlock
                                                                Grid.Row="1"
                                                                Grid.ColumnSpan="3"
                                                                Margin="0,10,0,0"
                                                                FontSize="13"
                                                                Foreground="#AAB6C5"
                                                                LineHeight="19"
                                                                Text="{Binding Message}"
                                                                TextWrapping="Wrap" />

                                                            <StackPanel
                                                                Grid.Row="2"
                                                                Grid.ColumnSpan="3"
                                                                Margin="0,12,0,0"
                                                                Orientation="Horizontal">
                                                                <Border
                                                                    x:Name="NotificationTypePill"
                                                                    Margin="0,0,8,0"
                                                                    Padding="8,3"
                                                                    Background="#1F2A37"
                                                                    CornerRadius="10">
                                                                    <TextBlock
                                                                        x:Name="NotificationTypeText"
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#DDE6F1"
                                                                        Text="Инфо" />
                                                                </Border>

                                                                <Border
                                                                    Background="#24303E"
                                                                    CornerRadius="10"
                                                                    Padding="8,3"
                                                                    Visibility="{Binding IsRead, Converter={StaticResource BoolToVisibilityInverse}}">
                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#C8D6E7"
                                                                        Text="Новое" />
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger SourceName="NotificationCard" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="NotificationCard" Property="Background" Value="#19212B" />
                                                        <Setter TargetName="NotificationCard" Property="BorderBrush" Value="#344253" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                        <Setter TargetName="NotificationCard" Property="BorderBrush" Value="#405064" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static notify:NotificationType.Success}">
                                                        <Setter TargetName="NotificationAccent" Property="Background" Value="#48A975" />
                                                        <Setter TargetName="NotificationTypePill" Property="Background" Value="#163124" />
                                                        <Setter TargetName="NotificationTypeText" Property="Foreground" Value="#BCEFCF" />
                                                        <Setter TargetName="NotificationTypeText" Property="Text" Value="Успех" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static notify:NotificationType.Warning}">
                                                        <Setter TargetName="NotificationAccent" Property="Background" Value="#D38E4A" />
                                                        <Setter TargetName="NotificationTypePill" Property="Background" Value="#392615" />
                                                        <Setter TargetName="NotificationTypeText" Property="Foreground" Value="#FFD6A5" />
                                                        <Setter TargetName="NotificationTypeText" Property="Text" Value="Внимание" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static notify:NotificationType.Error}">
                                                        <Setter TargetName="NotificationAccent" Property="Background" Value="#C76363" />
                                                        <Setter TargetName="NotificationTypePill" Property="Background" Value="#3B1C1C" />
                                                        <Setter TargetName="NotificationTypeText" Property="Foreground" Value="#FFC4C4" />
                                                        <Setter TargetName="NotificationTypeText" Property="Text" Value="Ошибка" />
                                                        <Setter TargetName="NotificationTitle" Property="Foreground" Value="#FFF0F0" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
