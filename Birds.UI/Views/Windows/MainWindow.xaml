<Window
    x:Class="Birds.UI.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notify="clr-namespace:Birds.UI.Services.Notification"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:Birds.UI.ViewModels"
    Title="Birds"
    Width="1360"
    Height="840"
    MinWidth="1080"
    MinHeight="700"
    Background="#161A20"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    mc:Ignorable="d">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#C8D0DA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#202733" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#2B3442" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CloseTitleBarButtonStyle"
            BasedOn="{StaticResource TitleBarButtonStyle}"
            TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#B24A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#943C3C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToastCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#A8B4C4" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="CloseButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseButtonSurface" Property="Background" Value="#212936" />
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseButtonSurface" Property="Background" Value="#2A3442" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="#161A20"
        BorderBrush="#252B33"
        BorderThickness="1">
        <Grid Background="#161A20">
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#0F1318"
                BorderBrush="#252B33"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="16"
                        Height="16"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="#202733"
                        BorderBrush="#2C3642"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="9"
                            Foreground="#DDE4EC"
                            Text="B" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Click="OnMinimizeClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="10"
                                Height="10"
                                SnapsToDevicePixels="True">
                                <Border
                                    Height="1.4"
                                    VerticalAlignment="Center"
                                    Background="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            </Grid>
                        </Button>

                        <Button
                            Click="OnMaximizeRestoreClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <Grid
                                Width="12"
                                Height="12"
                                SnapsToDevicePixels="True">
                                <Rectangle
                                    x:Name="MaximizeGlyph"
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeThickness="1.2" />
                                <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        Margin="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                        StrokeThickness="1.1" />
                                </Grid>
                            </Grid>
                        </Button>

                        <Button
                            Click="OnCloseClick"
                            Style="{StaticResource CloseTitleBarButtonStyle}">
                            <Grid
                                Width="11"
                                Height="11"
                                SnapsToDevicePixels="True">
                                <Path
                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeThickness="1.5"
                                    Data="M 1 1 L 10 10 M 10 1 L 1 10" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="#101318"
                    BorderBrush="#252B33"
                    BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="24,24,24,20">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="26"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Birds" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Margin="14,0,14,0"
                            VerticalAlignment="Center">
                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:AddBirdViewModel}"
                                IsChecked="True"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Добавить птицу" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdListViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Архив" />
                            </RadioButton>

                            <RadioButton
                                Command="{Binding Path=Navigation.NavigateToTypeCommand, Mode=OneWay}"
                                CommandParameter="{x:Type vm:BirdStatisticsViewModel}"
                                Style="{StaticResource MenuButtonTheme}">
                                <TextBlock Text="Статистика" />
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Margin="28,26,28,0"
                        Width="760"
                        MaxWidth="760"
                        HorizontalAlignment="Center"
                        Padding="0,0,0,18"
                        BorderBrush="#252B33"
                        BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowContentHeader}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding HeaderTitle}" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                FontSize="14"
                                Foreground="#8E98A6"
                                Text="{Binding HeaderSubtitle}" />
                        </StackPanel>
                    </Border>

                    <ContentControl
                        Grid.Row="1"
                        Margin="24"
                        Content="{Binding Path=Navigation.Current}" />

                    <ItemsControl
                        Grid.RowSpan="2"
                        Margin="0,16,20,18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ItemsSource="{Binding Notifications}"
                        Panel.ZIndex="20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,0,14" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type notify:NotificationToast}">
                                <Border
                                    x:Name="ToastCard"
                                    Width="356"
                                    Background="#151B23"
                                    BorderBrush="#2F3946"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Opacity="0">
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="24"
                                            Color="#000000"
                                            Direction="270"
                                            Opacity="0.28"
                                            ShadowDepth="10" />
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.985" ScaleY="0.985" />
                                            <TranslateTransform X="18" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        Duration="0:0:0.2"
                                                        To="1" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                        Duration="0:0:0.2"
                                                        To="0" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                        Duration="0:0:0.2"
                                                        To="1" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                        Duration="0:0:0.2"
                                                        To="1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>

                                    <Grid ClipToBounds="True">
                                        <Border
                                            x:Name="AccentBar"
                                            Width="5"
                                            HorizontalAlignment="Left"
                                            Background="#7C8EA3"
                                            CornerRadius="16,0,0,16" />

                                        <Grid Margin="18,16,16,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border
                                                x:Name="BadgeSurface"
                                                Width="30"
                                                Height="30"
                                                Margin="0,0,14,0"
                                                VerticalAlignment="Top"
                                                Background="#233041"
                                                CornerRadius="15">
                                                <TextBlock
                                                    x:Name="BadgeText"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Foreground="#DDE6F1"
                                                    Text="i" />
                                            </Border>

                                            <TextBlock
                                                x:Name="ToastTitle"
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="#F3F6FA"
                                                TextWrapping="Wrap"
                                                Text="{Binding Title}" />

                                            <Button
                                                x:Name="ToastCloseButton"
                                                Grid.Column="2"
                                                Command="{Binding DataContext.DismissNotificationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToastCloseButtonStyle}">
                                                <Path
                                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                    StrokeStartLineCap="Round"
                                                    StrokeEndLineCap="Round"
                                                    StrokeThickness="1.4"
                                                    Data="M 1 1 L 9 9 M 9 1 L 1 9" />
                                            </Button>

                                            <TextBlock
                                                x:Name="ToastMessage"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Grid.ColumnSpan="2"
                                                Margin="0,9,0,0"
                                                FontSize="13"
                                                Foreground="#AEB9C7"
                                                LineHeight="19"
                                                Text="{Binding Message}"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="ToastCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ToastCard" Property="BorderBrush" Value="#415063" />
                                        <Setter TargetName="ToastCard" Property="Background" Value="#18202A" />
                                        <Setter TargetName="ToastCloseButton" Property="Opacity" Value="1" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static notify:NotificationType.Success}">
                                        <Setter TargetName="AccentBar" Property="Background" Value="#48A975" />
                                        <Setter TargetName="BadgeSurface" Property="Background" Value="#163124" />
                                        <Setter TargetName="BadgeText" Property="Text" Value="OK" />
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="#BCEFCF" />
                                        <Setter TargetName="ToastTitle" Property="Foreground" Value="#F2FAF5" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static notify:NotificationType.Warning}">
                                        <Setter TargetName="AccentBar" Property="Background" Value="#D38E4A" />
                                        <Setter TargetName="BadgeSurface" Property="Background" Value="#392615" />
                                        <Setter TargetName="BadgeText" Property="Text" Value="!" />
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="#FFD6A5" />
                                        <Setter TargetName="ToastTitle" Property="Foreground" Value="#FFF6E8" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static notify:NotificationType.Error}">
                                        <Setter TargetName="AccentBar" Property="Background" Value="#C76363" />
                                        <Setter TargetName="BadgeSurface" Property="Background" Value="#3B1C1C" />
                                        <Setter TargetName="BadgeText" Property="Text" Value="!" />
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="#FFC4C4" />
                                        <Setter TargetName="ToastTitle" Property="Foreground" Value="#FFF0F0" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
