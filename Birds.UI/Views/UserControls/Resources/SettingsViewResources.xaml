<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sync="clr-namespace:Birds.Shared.Sync;assembly=Birds.Shared"
    mc:Ignorable="d">
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource ThemeCardBackgroundColor}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{DynamicResource ThemeCardBorderColor}" />
    <SolidColorBrush x:Key="InsetBackgroundBrush" Color="{DynamicResource ThemeInsetBackgroundColor}" />
    <SolidColorBrush x:Key="FieldBackgroundBrush" Color="{DynamicResource ThemeFieldBackgroundColor}" />
    <SolidColorBrush x:Key="FieldBorderBrush" Color="{DynamicResource ThemeFieldBorderColor}" />
    <SolidColorBrush x:Key="FieldBorderHoverBrush" Color="{DynamicResource ThemeFieldBorderHoverColor}" />
    <SolidColorBrush x:Key="FieldBorderFocusBrush" Color="{DynamicResource ThemeFieldBorderFocusColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource ThemePrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{DynamicResource ThemeSecondaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource ThemeMutedTextColor}" />
    <SolidColorBrush x:Key="AccentButtonBrush" Color="{DynamicResource ThemeAccentButtonColor}" />
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="{DynamicResource ThemeAccentButtonHoverColor}" />
    <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="{DynamicResource ThemeAccentButtonBorderColor}" />
    <SolidColorBrush x:Key="DangerButtonBrush" Color="{DynamicResource ThemeDangerButtonColor}" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="{DynamicResource ThemeDangerButtonHoverColor}" />
    <SolidColorBrush x:Key="DangerButtonBorderBrush" Color="{DynamicResource ThemeDangerButtonBorderColor}" />
    <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="{DynamicResource ThemeDangerButtonForegroundColor}" />

    <Style x:Key="SettingsCardStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="Background" Value="{StaticResource InsetBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style
        x:Key="DangerSectionTitleStyle"
        BasedOn="{StaticResource SectionTitleStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource DangerButtonForegroundBrush}" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="FieldHintStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SettingsFieldGroupStyle" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="SectionBodyStackStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="SettingsRowContentStackStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="SettingsToggleRowStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,20,0,0" />
        <Setter Property="Padding" Value="10,14" />
        <Setter Property="Background" Value="{StaticResource InsetBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style
        x:Key="DangerRowStyle"
        BasedOn="{StaticResource SettingsToggleRowStyle}"
        TargetType="Border" />

    <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="ItemBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{StaticResource InsetBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{StaticResource AccentButtonBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MaxDropDownHeight" Value="280" />
        <Setter Property="Padding" Value="14,0,42,0" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border
                            x:Name="FieldBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" />

                        <TextBlock
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Foreground="{TemplateBinding Foreground}"
                            IsHitTestVisible="False"
                            Text="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource TemplatedParent}}"
                            TextTrimming="CharacterEllipsis" />

                        <Path
                            Width="11"
                            Height="7"
                            Margin="0,0,16,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Data="M 0 0 L 5.5 5.5 L 11 0"
                            Stroke="{StaticResource SecondaryTextBrush}"
                            StrokeThickness="1.6" />

                        <ToggleButton
                            Background="Transparent"
                            BorderThickness="0"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            Opacity="0" />

                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom"
                            PopupAnimation="Fade">
                            <Border
                                Margin="0,6,0,0"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Padding="8,8,6,8"
                                Background="{StaticResource InsetBackgroundBrush}"
                                BorderBrush="{StaticResource FieldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <ScrollViewer
                                    CanContentScroll="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="FieldBorder" Property="BorderBrush"
                                    Value="{StaticResource FieldBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FieldBorder" Property="BorderBrush"
                                    Value="{StaticResource FieldBorderFocusBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        ClipToBounds="False">
                        <Border
                            x:Name="Track"
                            Background="{DynamicResource ThemeToggleTrackOffBrush}"
                            BorderBrush="{DynamicResource ThemeToggleBorderOffBrush}"
                            BorderThickness="1"
                            CornerRadius="13" />

                        <Ellipse
                            Width="20"
                            Height="20"
                            Margin="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource ThemePrimaryTextBrush}"
                            RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="ThumbTransform" X="0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush"
                                    Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"
                                    Value="{DynamicResource ThemeToggleTrackOnBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush"
                                    Value="{DynamicResource ThemeToggleBorderOnBrush}" />
                        </Trigger>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="ThumbTransform"
                                        Storyboard.TargetProperty="X"
                                        To="20"
                                        Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="ThumbTransform"
                                        Storyboard.TargetProperty="X"
                                        To="0"
                                        Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42" />
        <Setter Property="MinWidth" Value="168" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="{StaticResource AccentButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{StaticResource AccentButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.94" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="DataActionButtonStyle"
        BasedOn="{StaticResource SecondaryButtonStyle}"
        TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="110" />
        <Setter Property="Margin" Value="14,0,0,0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>

    <Style
        x:Key="CompactMetaActionButtonStyle"
        BasedOn="{StaticResource DataActionButtonStyle}"
        TargetType="Button">
        <Setter Property="Height" Value="30" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    </Style>

    <Style
        x:Key="DangerActionButtonStyle"
        BasedOn="{StaticResource DataActionButtonStyle}"
        TargetType="Button">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource DangerButtonForegroundBrush}" />
        <Setter Property="Background" Value="{StaticResource DangerButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{StaticResource DangerButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.94" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="DangerConfirmPanelStyle"
        TargetType="Border">
        <Setter Property="Margin" Value="0,14,0,0" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style
        x:Key="SyncWarningPanelStyle"
        TargetType="Border">
        <Setter Property="Margin" Value="0,14,0,0" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="SettingsSyncStatusPillStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="{StaticResource AccentButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="11" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RemoteSyncStatus}"
                         Value="{x:Static sync:RemoteSyncDisplayState.Syncing}">
                <Setter Property="BorderBrush" Value="{StaticResource FieldBorderFocusBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Synced}">
                <Setter Property="Background" Value="{DynamicResource ThemeStatusAliveBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Paused}">
                <Setter Property="Background" Value="{StaticResource AccentButtonBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}"
                         Value="{x:Static sync:RemoteSyncDisplayState.Offline}">
                <Setter Property="BorderBrush" Value="{StaticResource FieldBorderFocusBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Error}">
                <Setter Property="Background" Value="{DynamicResource ThemeStatusDeadBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsSyncStatusDotStyle" TargetType="Ellipse">
        <Setter Property="Fill" Value="{StaticResource SecondaryTextBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RemoteSyncStatus}"
                         Value="{x:Static sync:RemoteSyncDisplayState.Syncing}">
                <Setter Property="Fill" Value="{StaticResource FieldBorderFocusBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Synced}">
                <Setter Property="Fill" Value="{DynamicResource ThemeStatusAliveBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Paused}">
                <Setter Property="Fill" Value="{StaticResource FieldBorderHoverBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}"
                         Value="{x:Static sync:RemoteSyncDisplayState.Offline}">
                <Setter Property="Fill" Value="{StaticResource FieldBorderFocusBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RemoteSyncStatus}" Value="{x:Static sync:RemoteSyncDisplayState.Error}">
                <Setter Property="Fill" Value="{DynamicResource ThemeStatusDeadBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsSyncActivityCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Synced}">
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Paused}">
                <Setter Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Offline}">
                <Setter Property="BorderBrush" Value="{StaticResource FieldBorderFocusBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Error}">
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsSyncActivityDotStyle" TargetType="Ellipse">
        <Setter Property="Fill" Value="{StaticResource SecondaryTextBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Synced}">
                <Setter Property="Fill" Value="{DynamicResource ThemeStatusAliveBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Paused}">
                <Setter Property="Fill" Value="{StaticResource FieldBorderHoverBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Offline}">
                <Setter Property="Fill" Value="{StaticResource FieldBorderFocusBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static sync:RemoteSyncDisplayState.Error}">
                <Setter Property="Fill" Value="{DynamicResource ThemeStatusDeadBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="ConfirmSecondaryButtonStyle"
        BasedOn="{StaticResource DataActionButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="16,0" />
    </Style>

    <Style
        x:Key="ConfirmDangerButtonStyle"
        BasedOn="{StaticResource DangerActionButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="136" />
        <Setter Property="Padding" Value="16,0" />
    </Style>

    <Style
        x:Key="ConfirmWideDangerButtonStyle"
        BasedOn="{StaticResource ConfirmDangerButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="186" />
        <Setter Property="Padding" Value="20,0" />
    </Style>

    <Style
        x:Key="ConfirmExtraWideDangerButtonStyle"
        BasedOn="{StaticResource ConfirmWideDangerButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="232" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <Style
        x:Key="CompactDataComboBoxItemStyle"
        BasedOn="{StaticResource SettingsComboBoxItemStyle}"
        TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style
        x:Key="CompactDataComboBoxStyle"
        BasedOn="{StaticResource SettingsComboBoxStyle}"
        TargetType="ComboBox">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="MaxDropDownHeight" Value="180" />
        <Setter Property="Padding" Value="12,0,34,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource CompactDataComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border
                            x:Name="FieldBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" />

                        <TextBlock
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Foreground="{TemplateBinding Foreground}"
                            IsHitTestVisible="False"
                            Text="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource TemplatedParent}}"
                            TextTrimming="CharacterEllipsis" />

                        <Path
                            Width="10"
                            Height="6"
                            Margin="0,0,14,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Data="M 0 0 L 5 5 L 10 0"
                            Stroke="{StaticResource SecondaryTextBrush}"
                            StrokeThickness="1.5" />

                        <ToggleButton
                            Background="Transparent"
                            BorderThickness="0"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            Opacity="0" />

                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom"
                            PopupAnimation="Fade">
                            <Border
                                Margin="0,4,0,0"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Padding="4,4,4,4"
                                Background="{StaticResource InsetBackgroundBrush}"
                                BorderBrush="{StaticResource FieldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <ScrollViewer
                                    CanContentScroll="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="FieldBorder" Property="BorderBrush"
                                    Value="{StaticResource FieldBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FieldBorder" Property="BorderBrush"
                                    Value="{StaticResource FieldBorderFocusBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

