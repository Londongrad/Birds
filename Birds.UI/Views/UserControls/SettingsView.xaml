                            <Button
                                Grid.Column="1"
                                Command="{Binding ResetPreferencesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{loc:Loc Key=Settings.ResetButton}" />
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
