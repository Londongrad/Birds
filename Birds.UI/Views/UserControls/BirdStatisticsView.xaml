<UserControl
    x:Class="Birds.UI.Views.UserControls.BirdStatisticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:Birds.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:BirdStatisticsViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="980"
    mc:Ignorable="d">

    <!-- Dark background + page padding -->
    <Border Style="{StaticResource ViewsBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title + filter line -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,16">
                <TextBlock
                    Style="{StaticResource TextBlockStats}"
                    Text="Статистика по птицам" />

                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Style="{StaticResource TextBlockStats}"
                        Text="Год:" />
                    <ComboBox
                        Margin="8,0,8,0"
                        ItemsSource="{Binding AvailableYears}"
                        SelectedItem="{Binding SelectedYear,
                                               Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource ComboBoxYears}" />
                    <Button
                        Command="{Binding ClearYearFilterCommand}"
                        Content="Все года"
                        Style="{StaticResource StatsBirdButton}" />
                </StackPanel>
            </StackPanel>

            <!-- Content area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: metric cards -->
                <ScrollViewer
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                Text="{Binding TotalBirds,
                                               StringFormat=Всего поймано: {0}}" />
                        </Border>

                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="16"
                                Foreground="{DynamicResource ThemeStatsSuccessBrush}"
                                Text="{Binding ReleasedCount,
                                               StringFormat=Отпущено: {0}}" />
                        </Border>

                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="16"
                                Foreground="{DynamicResource ThemeStatsInfoBrush}"
                                Text="{Binding KillCount,
                                               StringFormat=Уничтожено: {0}}" />
                        </Border>

                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="14"
                                Foreground="{DynamicResource ThemeStatsHighlightBrush}"
                                Text="{Binding TopMonth,
                                               StringFormat=Самый продуктивный месяц: {0}}" />
                        </Border>

                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="14"
                                Foreground="{DynamicResource ThemeStatsHighlightBrush}"
                                Text="{Binding TopWeek,
                                               StringFormat=Самая продуктивная неделя: {0}}" />
                        </Border>

                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="14"
                                Foreground="{DynamicResource ThemeStatsHighlightBrush}"
                                Text="{Binding TopDay,
                                               StringFormat=Самый продуктивный день: {0}}" />
                        </Border>

                        <Border Style="{StaticResource MetricCardBorder}">
                            <TextBlock
                                FontSize="14"
                                Foreground="{DynamicResource ThemeStatsHighlightBrush}"
                                Text="{Binding LongestBreak,
                                               StringFormat=Самый большой перерыв: {0}}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- RIGHT: tabs with lists + SCROLL -->
                <TabControl Grid.Column="1">

                    <!-- Species -->
                    <TabItem Header="По видам">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                Margin="0,8,0,0"
                                ItemsSource="{Binding SpeciesStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10"
                                            Background="{DynamicResource ThemeStatsListItemBrush}"
                                            CornerRadius="8">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock
                                                    Margin="0,0,10,0"
                                                    DockPanel.Dock="Left"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    DockPanel.Dock="Right"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemeStatsSecondaryTextBrush}"
                                                    Text="{Binding Count}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <!-- By year -->
                    <TabItem Header="По годам">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                Margin="0,8,0,0"
                                ItemsSource="{Binding YearStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10"
                                            Background="{DynamicResource ThemeStatsListItemBrush}"
                                            CornerRadius="8">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock
                                                    Margin="0,0,10,0"
                                                    DockPanel.Dock="Left"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    DockPanel.Dock="Right"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemeStatsSecondaryTextBrush}"
                                                    Text="{Binding Count}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <!-- By month -->
                    <TabItem Header="По месяцам">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                Margin="0,8,0,0"
                                ItemsSource="{Binding MonthStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10"
                                            Background="{DynamicResource ThemeStatsListItemBrush}"
                                            CornerRadius="8">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock
                                                    Margin="0,0,10,0"
                                                    DockPanel.Dock="Left"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    DockPanel.Dock="Right"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemeStatsSecondaryTextBrush}"
                                                    Text="{Binding Count}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <!-- The most prolonged keeping by species -->
                    <TabItem Header="По длительности содержания">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                Margin="0,8,0,0"
                                ItemsSource="{Binding LongestKeepingStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10"
                                            Background="{DynamicResource ThemeStatsListItemBrush}"
                                            CornerRadius="8">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock
                                                    Margin="0,0,10,0"
                                                    DockPanel.Dock="Left"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    DockPanel.Dock="Right"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource ThemeStatsSecondaryTextBrush}"
                                                    Text="{Binding Count,
                                                                   StringFormat={}{0} дней}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <Grid
                Grid.RowSpan="2"
                Background="{DynamicResource ThemeOverlayBrush}"
                Visibility="{Binding IsLoading,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <ProgressBar
                        Width="200"
                        Height="10"
                        IsIndeterminate="True" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="16"
                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                        Text="Загрузка..." />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
