<UserControl
    x:Class="Birds.UI.Views.UserControls.BirdStatisticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:Birds.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:BirdStatisticsViewModel}"
    d:DesignHeight="740"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="StatsSectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="StatsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
        </Style>

        <Style x:Key="StatsSectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StatsMetricCardStyle" BasedOn="{StaticResource StatsSectionCardStyle}" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="118" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="StatsItemCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{DynamicResource ThemeInsetBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="StatsActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatsCountBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatsFilterComboBoxStyle" BasedOn="{StaticResource ComboBox}" TargetType="ComboBox">
            <Setter Property="Width" Value="190" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Margin" Value="14,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatsTabItemStyle" TargetType="TabItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ThemeFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10,22,10" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="HeaderBorder"
                            Margin="1,1,16,1"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="False"
                            CornerRadius="18">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderFocusBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource ThemeFieldBorderHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid ClipToBounds="False" KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TabPanel
                                x:Name="HeaderPanel"
                                Grid.Row="0"
                                ClipToBounds="False"
                                Margin="2,0,2,18"
                                Background="Transparent"
                                IsItemsHost="True"
                                KeyboardNavigation.TabIndex="1"
                                Panel.ZIndex="1" />

                            <ContentPresenter
                                x:Name="PART_SelectedContentHost"
                                Grid.Row="1"
                                ContentSource="SelectedContent"
                                KeyboardNavigation.DirectionalNavigation="Contained" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CountStatTemplate">
            <Border Style="{StaticResource StatsItemCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Margin="0,0,16,0"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                        Text="{Binding Label}"
                        TextWrapping="Wrap" />
                    <Border Grid.Column="1" Style="{StaticResource StatsCountBadgeStyle}">
                        <TextBlock
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="{DynamicResource ThemePrimaryTextBrush}"
                            Text="{Binding Count}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DurationStatTemplate">
            <Border Style="{StaticResource StatsItemCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Margin="0,0,16,0"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                        Text="{Binding Label}"
                        TextWrapping="Wrap" />
                    <Border Grid.Column="1" Style="{StaticResource StatsCountBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                Text="{Binding Count}" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                                Text="{loc:Loc Key=Bird.DaysSuffix}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource ViewsBorder}">
        <Grid>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
                <StackPanel MaxWidth="1120">
                    <DockPanel Margin="0,0,0,20" LastChildFill="False">
                        <Border
                            Padding="14,10"
                            Background="{DynamicResource ThemeFieldBackgroundBrush}"
                            BorderBrush="{DynamicResource ThemeCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            DockPanel.Dock="Right">
                            <DockPanel LastChildFill="True">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ThemeMutedTextBrush}"
                                    Text="{loc:Loc Key=Statistics.Year}" />
                                <ComboBox
                                    DisplayMemberPath="Label"
                                    ItemsSource="{Binding YearFilters}"
                                    SelectedItem="{Binding SelectedYearFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource StatsFilterComboBoxStyle}" />
                            </DockPanel>
                        </Border>
                    </DockPanel>

                    <Border Margin="0,0,0,20">
                        <Border.Style>
                            <Style BasedOn="{StaticResource StatsSectionCardStyle}" TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBirds}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TabControl Style="{StaticResource StatsTabControlStyle}">
                            <TabControl.Resources>
                                <Style TargetType="TabItem" BasedOn="{StaticResource StatsTabItemStyle}" />
                            </TabControl.Resources>

                            <TabItem Header="{loc:Loc Key=Statistics.Tab.Overview}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
                                    <StackPanel Margin="0,18,0,0">
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                                            Text="{Binding FilterSummary}"
                                            TextWrapping="Wrap" />

                                        <Grid Margin="0,18,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource StatsMetricCardStyle}" BorderBrush="{DynamicResource ThemeAccentButtonBorderBrush}">
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeSecondaryTextBrush}" Text="{loc:Loc Key=Statistics.Card.Total}" />
                                                    <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryTextBrush}" Text="{Binding TotalBirds}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource StatsMetricCardStyle}" BorderBrush="{DynamicResource ThemeStatusAliveBorderBrush}">
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeSecondaryTextBrush}" Text="{loc:Loc Key=Statistics.Card.Alive}" />
                                                    <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ThemeStatusAliveBrush}" Text="{Binding AliveCount}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Margin="0,0,16,0" Style="{StaticResource StatsMetricCardStyle}" BorderBrush="{DynamicResource ThemeStatsSuccessBrush}">
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeSecondaryTextBrush}" Text="{loc:Loc Key=Statistics.Card.Released}" />
                                                    <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ThemeStatsSuccessBrush}" Text="{Binding ReleasedCount}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="3" Style="{StaticResource StatsMetricCardStyle}" BorderBrush="{DynamicResource ThemeStatusDeadBorderBrush}">
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeSecondaryTextBrush}" Text="{loc:Loc Key=Statistics.Card.Dead}" />
                                                    <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ThemeStatusDeadBrush}" Text="{Binding KillCount}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="0.8*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Margin="0,0,18,0" Style="{StaticResource StatsItemCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.Section.Highlights.Title}" />
                                                    <TextBlock Style="{StaticResource StatsSectionDescriptionStyle}" Text="{loc:Loc Key=Statistics.Section.Highlights.Description}" />

                                                    <UniformGrid Margin="0,18,0,0" Columns="2">
                                                        <Border Margin="0,0,12,12" Style="{StaticResource StatsItemCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock FontSize="12" Foreground="{DynamicResource ThemeMutedTextBrush}" Text="{loc:Loc Key=Statistics.Highlight.AverageKeeping}" />
                                                                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemePrimaryTextBrush}" Text="{Binding AverageKeeping}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Margin="0,0,0,12" Style="{StaticResource StatsItemCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock FontSize="12" Foreground="{DynamicResource ThemeMutedTextBrush}" Text="{loc:Loc Key=Statistics.Highlight.TopMonth}" />
                                                                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemePrimaryTextBrush}" Text="{Binding TopMonth}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Margin="0,0,12,0" Style="{StaticResource StatsItemCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock FontSize="12" Foreground="{DynamicResource ThemeMutedTextBrush}" Text="{loc:Loc Key=Statistics.Highlight.TopWeek}" />
                                                                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemePrimaryTextBrush}" Text="{Binding TopWeek}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Margin="0" Style="{StaticResource StatsItemCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock FontSize="12" Foreground="{DynamicResource ThemeMutedTextBrush}" Text="{loc:Loc Key=Statistics.Highlight.TopDay}" />
                                                                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemePrimaryTextBrush}" Text="{Binding TopDay}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Style="{StaticResource StatsItemCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.Highlight.LongestBreak}" />
                                                    <TextBlock Style="{StaticResource StatsSectionDescriptionStyle}" Text="{loc:Loc Key=Statistics.Section.OverviewBreakDescription}" />
                                                    <Border Margin="0,18,0,0" Style="{StaticResource StatsItemCardStyle}">
                                                        <TextBlock
                                                            FontSize="18"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource ThemePrimaryTextBrush}"
                                                            Text="{Binding LongestBreak}"
                                                            TextWrapping="Wrap" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="{loc:Loc Key=Statistics.Tab.Distribution}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
                                    <Grid Margin="0,18,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="0.9*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,18,18" Style="{StaticResource StatsItemCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.Section.Species.Title}" />
                                                    <TextBlock Style="{StaticResource StatsSectionDescriptionStyle}" Text="{loc:Loc Key=Statistics.Section.Species.Description}" />
                                                </StackPanel>
                                                <ScrollViewer Grid.Row="1" MaxHeight="300" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemTemplate="{StaticResource CountStatTemplate}" ItemsSource="{Binding SpeciesStats}" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="1" Margin="0,0,0,18" Style="{StaticResource StatsItemCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.Section.Years.Title}" />
                                                    <TextBlock Style="{StaticResource StatsSectionDescriptionStyle}" Text="{loc:Loc Key=Statistics.Section.Years.Description}" />
                                                </StackPanel>
                                                <ScrollViewer Grid.Row="1" MaxHeight="300" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemTemplate="{StaticResource CountStatTemplate}" ItemsSource="{Binding YearStats}" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource StatsItemCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.Section.Months.Title}" />
                                                    <TextBlock Style="{StaticResource StatsSectionDescriptionStyle}" Text="{loc:Loc Key=Statistics.Section.Months.Description}" />
                                                </StackPanel>
                                                <ScrollViewer Grid.Row="1" MaxHeight="300" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemTemplate="{StaticResource CountStatTemplate}" ItemsSource="{Binding MonthStats}" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="{loc:Loc Key=Statistics.Tab.Keeping}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
                                    <Border Margin="0,18,0,0" Style="{StaticResource StatsItemCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Margin="0,0,0,16">
                                                <TextBlock Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.Section.Keeping.Title}" />
                                                <TextBlock Style="{StaticResource StatsSectionDescriptionStyle}" Text="{loc:Loc Key=Statistics.Section.Keeping.Description}" />
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="1" MaxHeight="380" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemTemplate="{StaticResource DurationStatTemplate}" ItemsSource="{Binding LongestKeepingStats}" />
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>

                    <Border Margin="0,0,0,4">
                        <Border.Style>
                            <Style BasedOn="{StaticResource StatsSectionCardStyle}" TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBirds}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource StatsSectionTitleStyle}" Text="{loc:Loc Key=Statistics.EmptyTitle}" />
                            <TextBlock
                                Width="420"
                                HorizontalAlignment="Center"
                                Style="{StaticResource StatsSectionDescriptionStyle}"
                                Text="{loc:Loc Key=Statistics.EmptyDescription}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Background="{DynamicResource ThemeOverlayBrush}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="220" Height="10" IsIndeterminate="True" />
                    <TextBlock Margin="0,12,0,0" FontSize="16" Foreground="{DynamicResource ThemePrimaryTextBrush}" Text="{loc:Loc Key=Statistics.Loading}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
