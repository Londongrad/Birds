<UserControl
    x:Class="Birds.UI.Views.UserControls.BirdItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:Birds.UI.Services.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:Birds.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:BirdViewModel}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Birds.UI;component/wwwroot/Themes/BirdListView/BirdItemTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        MinHeight="132"
        Margin="0,0,0,12"
        Padding="18"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ThemeBirdItemBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ThemeNotificationCardBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ThemeNotificationUnreadBorderBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="HeaderRow"
                Grid.Row="0"
                VerticalAlignment="Top">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                    Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}},
                                   Path=DisplayIndex}" />

                <Border
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="10,5"
                    VerticalAlignment="Center"
                    CornerRadius="999">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ThemeStatusAliveBackgroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusAliveBorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeStatusDeadBorderBrush}" />
                                    <Setter Property="Background" Value="{DynamicResource ThemeStatusDeadBackgroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemePrimaryTextBrush}"
                        Text="{Binding StatusText}" />
                </Border>

                <Border
                    Grid.Column="2"
                    Width="20"
                    Height="20"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource ThemeNotificationActionBrush}"
                    BorderBrush="{DynamicResource ThemeCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <ToolTipService.ToolTip>
                        <TextBlock>
                            <Run Text="{loc:Loc Key=Bird.CreatedLabel}" />
                            <Run Text="{Binding LocalCreatedAtDisplay, Mode=OneWay}" />
                            <LineBreak />
                            <Run Text="{loc:Loc Key=Bird.UpdatedLabel}" />
                            <Run Text="{Binding LocalUpdatedAtDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </ToolTipService.ToolTip>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ThemeSecondaryTextBrush}"
                        Text="i" />
                </Border>
            </Grid>

            <ContentControl
                Grid.Row="1"
                Margin="0,8,0,0"
                Content="{Binding}"
                Validation.ErrorTemplate="{StaticResource NoErrorTemplate}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource BirdViewTemplate}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource BirdEditTemplate}" />
                                <Setter Property="Margin" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>
