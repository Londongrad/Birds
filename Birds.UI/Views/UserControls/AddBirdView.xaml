<UserControl
    x:Class="Birds.UI.Views.UserControls.AddBirdView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Birds.UI.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:Birds.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:AddBirdViewModel}"
    d:DesignHeight="640"
    d:DesignWidth="820"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style
            x:Key="AddBirdLabel"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#D8DEE7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style
            x:Key="AddBirdInputTextBox"
            BasedOn="{StaticResource TextBoxAdd}"
            TargetType="TextBox">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="46" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#39424D" />
            <Setter Property="Foreground" Value="#F3F5F7" />
            <Setter Property="CaretBrush" Value="#F3F5F7" />
            <Setter Property="Background" Value="#151A20" />
        </Style>

        <Style
            x:Key="AddBirdDescriptionTextBox"
            BasedOn="{StaticResource AddBirdInputTextBox}"
            TargetType="TextBox">
            <Setter Property="Height" Value="120" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style
            x:Key="AddBirdComboBox"
            BasedOn="{StaticResource ComboBox}"
            TargetType="ComboBox">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="46" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#39424D" />
            <Setter Property="Foreground" Value="#F3F5F7" />
            <Setter Property="Background" Value="#151A20" />
        </Style>

        <Style
            x:Key="AddBirdDatePicker"
            BasedOn="{StaticResource DatePickerAdd}"
            TargetType="DatePicker">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="46" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="BorderBrush" Value="#39424D" />
            <Setter Property="Background" Value="#151A20" />
        </Style>

        <Style
            x:Key="AddBirdPrimaryButton"
            TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Background" Value="#E7ECF2" />
            <Setter Property="Foreground" Value="#11161C" />
            <Setter Property="BorderBrush" Value="#E7ECF2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource ViewsBorder}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock
                    HorizontalAlignment="Left"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Новая запись" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left"
                    FontSize="14"
                    Foreground="#8E98A6"
                    Text="Заполните основные сведения о птице. Форма собрана в один спокойный сценарий без лишних элементов." />
            </StackPanel>

            <Border
                Grid.Row="1"
                Margin="0,22,0,0"
                Padding="14"
                Background="#171B21"
                BorderBrush="#252B33"
                BorderThickness="1"
                CornerRadius="10">
                <TextBlock
                    HorizontalAlignment="Left"
                    FontSize="13"
                    Foreground="#B7C0CB"
                    Text="Если птица содержалась один день, включите режим разового содержания — дата выбытия будет проставлена автоматически." />
            </Border>

            <Border
                Grid.Row="2"
                Margin="0,22,0,0"
                Padding="22"
                Background="#13181E"
                BorderBrush="#252B33"
                BorderThickness="1"
                CornerRadius="12">
                <Grid MaxWidth="760">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock
                            Style="{StaticResource AddBirdLabel}"
                            Text="Вид птицы" />
                        <ComboBox
                            IsEditable="False"
                            ItemsSource="{Binding BirdNames}"
                            SelectedItem="{Binding SelectedBirdName,
                                                   Mode=TwoWay,
                                                   ValidatesOnNotifyDataErrors=True,
                                                   UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource AddBirdComboBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock
                            Style="{StaticResource AddBirdLabel}"
                            Text="Дата прибытия" />
                        <DatePicker
                            CalendarStyle="{DynamicResource DarkCalendarStyle}"
                            SelectedDate="{Binding Arrival,
                                                   Mode=TwoWay,
                                                   Converter={StaticResource DateOnlyConverter},
                                                   ValidatesOnNotifyDataErrors=True,
                                                   UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource AddBirdDatePicker}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,20,0,0">
                        <TextBlock
                            Style="{StaticResource AddBirdLabel}"
                            Text="Описание" />
                        <TextBox
                            Style="{StaticResource AddBirdDescriptionTextBox}"
                            Text="{Binding Description,
                                           Mode=TwoWay,
                                           ValidatesOnNotifyDataErrors=True,
                                           UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Border
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Margin="0,20,0,0"
                        Padding="14"
                        Background="#161C23"
                        BorderBrush="#252B33"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="#D8DEE7"
                                    Text="Разовое содержание" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Left"
                                    FontSize="13"
                                    Foreground="#8E98A6"
                                    Text="Используйте этот режим, если птица прибыла и выбыла в один день." />
                            </StackPanel>

                            <CheckBox
                                Grid.Column="1"
                                Margin="20,0,0,0"
                                IsChecked="{Binding IsOneTime, Mode=TwoWay}"
                                Style="{StaticResource ToggleButton}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border
                Grid.Row="3"
                Margin="0,22,0,0"
                Padding="0"
                Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        FontSize="13"
                        Foreground="#8E98A6"
                        Text="После сохранения описание очистится, и можно будет сразу добавить следующую запись." />

                    <Button
                        Grid.Column="1"
                        Command="{Binding SaveCommand}">
                        <Button.Style>
                            <Style
                                BasedOn="{StaticResource AddBirdPrimaryButton}"
                                TargetType="Button">
                                <Setter Property="Content" Value="Сохранить запись" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Content" Value="Сохранение..." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
