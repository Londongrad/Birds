<UserControl
    x:Class="Birds.UI.Views.UserControls.AddBirdView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:Birds.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:AddBirdViewModel}"
    d:DesignHeight="640"
    d:DesignWidth="820"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1B212A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2B3441" />
        <SolidColorBrush x:Key="InsetBackgroundBrush" Color="#161C24" />
        <SolidColorBrush x:Key="FieldBackgroundBrush" Color="#11161D" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#313B48" />
        <SolidColorBrush x:Key="FieldBorderHoverBrush" Color="#425060" />
        <SolidColorBrush x:Key="FieldBorderFocusBrush" Color="#7C8EA3" />
        <SolidColorBrush x:Key="FieldBorderErrorBrush" Color="#C97A7A" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A3AFBD" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#7E8A98" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#E49999" />
        <SolidColorBrush x:Key="AccentButtonBrush" Color="#2D3744" />
        <SolidColorBrush x:Key="AccentButtonTextBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="InsetBorderHoverBrush" Color="#425060" />

        <Style x:Key="AnimatedCardStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="18" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.32">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                To="0"
                                Duration="0:0:0.34">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RevealSectionStyle" TargetType="Grid">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="10" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                BeginTime="0:0:0.08"
                                To="1"
                                Duration="0:0:0.24">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                BeginTime="0:0:0.08"
                                To="0"
                                Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RevealSectionDelayedStyle" TargetType="Grid">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="12" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                BeginTime="0:0:0.16"
                                To="1"
                                Duration="0:0:0.24">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                BeginTime="0:0:0.16"
                                To="0"
                                Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CardSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="FieldBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderFocusBrush}" />
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderErrorBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FieldBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="DescriptionTextBoxStyle"
            BasedOn="{StaticResource FormTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="MinHeight" Value="128" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="FormComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A2028" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#232C37" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="14,0,42,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource FormComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border
                                x:Name="FieldBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" />

                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                IsHitTestVisible="False" />

                            <Path
                                Width="11"
                                Height="7"
                                Margin="0,0,16,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Data="M 0 0 L 5.5 5.5 L 11 0"
                                Stroke="#96A3B3"
                                StrokeThickness="1.6" />

                            <ToggleButton
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen,
                                                    Mode=TwoWay,
                                                    RelativeSource={RelativeSource TemplatedParent}}"
                                Opacity="0" />

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    Margin="0,6,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource InsetBackgroundBrush}"
                                    BorderBrush="{StaticResource FieldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderFocusBrush}" />
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderErrorBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FieldBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="LegacyDatePickerBridgeStyle"
            BasedOn="{StaticResource DatePickerAdd}"
            TargetType="DatePicker">
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="46" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
        </Style>

        <Style x:Key="InsetPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource InsetBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource InsetBorderHoverBrush}" />
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    To="-2"
                                    Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    To="0"
                                    Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="Transparent">
                            <Border
                                x:Name="TrackBorder"
                                CornerRadius="13"
                                BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush x:Name="TrackBackgroundBrush" Color="#0F141B" />
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="TrackBorderBrush" Color="#334050" />
                                </Border.BorderBrush>
                            </Border>

                            <Ellipse
                                x:Name="Thumb"
                                Width="20"
                                Height="20"
                                Margin="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Fill="#F3F6FA"
                                RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="ThumbTransform" X="0" />
                                        <ScaleTransform x:Name="ThumbScaleTransform" ScaleX="1" ScaleY="1" />
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <Path
                                x:Name="CheckGlyph"
                                Width="8"
                                Height="6"
                                Margin="11,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Data="M 0 3 L 2.5 5.5 L 8 0"
                                Stroke="#11161D"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="1.4"
                                Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#4E5F74" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TrackBorder" Property="Background" Value="#2E5B86" />
                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#8EC7FF" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <EventTrigger RoutedEvent="ToggleButton.Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="20"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="0"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckBoxMarkStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border
                                    x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    Margin="0,2,12,0"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource FieldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Path
                                        x:Name="CheckMark"
                                        Data="M 2 9 L 7 14 L 16 4"
                                        Stroke="{StaticResource PrimaryTextBrush}"
                                        StrokeThickness="1.7"
                                        Stretch="Uniform"
                                        Visibility="Collapsed" />
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter VerticalAlignment="Top" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource FieldBorderFocusBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Background" Value="{StaticResource AccentButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            RenderTransformOrigin="0.5,0.5"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush x:Name="ButtonBackgroundBrush" Color="#2D3744" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="ButtonBorderBrush" Color="#2D3744" />
                            </Border.BorderBrush>
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ButtonScaleTransform" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="ButtonTranslateTransform" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonScaleTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1.02"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonScaleTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1.02"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonTranslateTransform"
                                                Storyboard.TargetProperty="Y"
                                                To="-1"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation
                                                Storyboard.TargetName="ButtonBackgroundBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#374353"
                                                Duration="0:0:0.18" />
                                            <ColorAnimation
                                                Storyboard.TargetName="ButtonBorderBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#425061"
                                                Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonScaleTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonScaleTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonTranslateTransform"
                                                Storyboard.TargetProperty="Y"
                                                To="0"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation
                                                Storyboard.TargetName="ButtonBackgroundBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#2D3744"
                                                Duration="0:0:0.18" />
                                            <ColorAnimation
                                                Storyboard.TargetName="ButtonBorderBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#2D3744"
                                                Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer
        x:Name="FormScrollViewer"
        VerticalScrollBarVisibility="Auto">
        <Grid
            Margin="24,12,24,24"
            MinHeight="{Binding ElementName=FormScrollViewer, Path=ViewportHeight}">
            <Border
                Style="{StaticResource AnimatedCardStyle}"
                Width="760"
                MaxWidth="760"
                Padding="32,28,32,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
                <Grid VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1" Margin="0,0,0,0" Style="{StaticResource RevealSectionStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Вид птицы" />
                        <ComboBox
                            x:Name="BirdNameField"
                            Grid.Row="1"
                            IsEditable="False"
                            ItemsSource="{Binding BirdNames}"
                            SelectedItem="{Binding SelectedBirdName,
                                                   Mode=TwoWay,
                                                   ValidatesOnNotifyDataErrors=True,
                                                   UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource FormComboBoxStyle}" />
                        <TextBlock
                            Grid.Row="2"
                            Text="{Binding ElementName=BirdNameField, Path=(Validation.Errors)[0].ErrorContent}">
                            <TextBlock.Style>
                                <Style
                                    BasedOn="{StaticResource ErrorTextStyle}"
                                    TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=BirdNameField, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Grid.Row="3" Margin="0,20,0,8" Style="{StaticResource FieldLabelStyle}" Text="Дата прибытия" />
                        <DatePicker
                            x:Name="ArrivalField"
                            Grid.Row="4"
                            SelectedDate="{Binding Arrival,
                                                   Mode=TwoWay,
                                                   Converter={StaticResource DateOnlyConverter},
                                                   ValidatesOnNotifyDataErrors=True,
                                                   UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource LegacyDatePickerBridgeStyle}" />
                        <TextBlock
                            Grid.Row="5"
                            Text="{Binding ElementName=ArrivalField, Path=(Validation.Errors)[0].ErrorContent}">
                            <TextBlock.Style>
                                <Style
                                    BasedOn="{StaticResource ErrorTextStyle}"
                                    TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ArrivalField, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Grid.Row="6" Margin="0,20,0,8" Style="{StaticResource FieldLabelStyle}" Text="Описание" />
                        <TextBox
                            x:Name="DescriptionField"
                            Grid.Row="7"
                            MaxLength="200"
                            Style="{StaticResource DescriptionTextBoxStyle}"
                            Text="{Binding Description,
                                           Mode=TwoWay,
                                           ValidatesOnNotifyDataErrors=True,
                                           UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,16,0,0" Style="{StaticResource RevealSectionDelayedStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource FieldHintStyle}"
                            Text="Описание необязательно. До 200 символов." />
                        <TextBlock
                            Grid.Row="1"
                            Text="{Binding ElementName=DescriptionField, Path=(Validation.Errors)[0].ErrorContent}">
                            <TextBlock.Style>
                                <Style
                                    BasedOn="{StaticResource ErrorTextStyle}"
                                    TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=DescriptionField, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Border
                            Grid.Row="2"
                            Margin="0,24,0,0"
                            Style="{StaticResource InsetPanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    Grid.Column="0"
                                    Margin="0,2,14,0"
                                    IsChecked="{Binding IsOneTime, Mode=TwoWay}"
                                    Style="{StaticResource ToggleSwitchStyle}"
                                    VerticalAlignment="Top" />

                                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="Разовое содержание" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Left"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        FontSize="12"
                                        Text="Если птица прибыла и выбыла в один день, дата выбытия заполнится автоматически." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Button
                                HorizontalAlignment="Right"
                                Command="{Binding SaveCommand}">
                                <Button.Style>
                                    <Style
                                        BasedOn="{StaticResource PrimaryButtonStyle}"
                                        TargetType="Button">
                                        <Setter Property="Content" Value="Сохранить запись" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Content" Value="Сохранение..." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
